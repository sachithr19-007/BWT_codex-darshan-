function doSignup() {
  const fname = document.getElementById('su-fname').value.trim();
  const lname = document.getElementById('su-lname').value.trim();
  const email = document.getElementById('su-email').value.trim();
  const branch = document.getElementById('su-branch').value;
  const year = document.getElementById('su-year').value;
  const pass = document.getElementById('su-pass').value;

  if(!fname||!lname) return showAuthErr('Please enter your full name.');
  if(!email||!email.includes('@')) return showAuthErr('Please enter a valid email.');
  if(!branch) return showAuthErr('Please select your branch.');
  if(pass.length < 6) return showAuthErr('Password must be at least 6 characters.');

  const users = JSON.parse(localStorage.getItem('enginex_users')||'{}');
  if(users[email]) return showAuthErr('An account with this email already exists. Please sign in.');

  const userData = {
    fname, lname, email, pass, branch, year,
    joined: new Date().toISOString(),
    data: { topics:12, tests:5, xp:850, avgScore:74, streak:3,
      activity:[{subj:'Python - Functions',score:82,date:'Today',type:'Test'},
                {subj:'DSA - Arrays',score:90,date:'Yesterday',type:'Test'},
                {subj:'JavaScript - Closures',score:0,date:'2 days ago',type:'Chat'},
                {subj:'DBMS - Joins',score:68,date:'3 days ago',type:'Test'}]
    }
  };
  users[email] = userData;
  localStorage.setItem('enginex_users', JSON.stringify(users));
  showAuthOk('Account created! Signing you in…');
  setTimeout(() => launchApp(userData), 1000);
}

function doLogin() {
  const email = document.getElementById('li-email').value.trim();
  const pass = document.getElementById('li-pass').value;
  if(!email) return showAuthErr('Please enter your email.');
  if(!pass) return showAuthErr('Please enter your password.');

  const users = JSON.parse(localStorage.getItem('enginex_users')||'{}');
  const user = users[email];
  if(!user) return showAuthErr('No account found. Please sign up first.');
  if(user.pass !== pass) return showAuthErr('Incorrect password. Please try again.');

  const remember = document.getElementById('li-remember').checked;
  if(remember) localStorage.setItem('enginex_session', email);
  launchApp(user);
}

function launchApp(user) {
  currentUser = user;
  apiKey = localStorage.getItem('enginex_apikey') || '';
  if(apiKey) document.getElementById('modelBadge').textContent = 'Claude AI';
  else document.getElementById('apiKeyCard').style.display = 'block';

  document.getElementById('authPage').style.opacity = '0';
  document.getElementById('authPage').style.transition = 'opacity 0.35s';
  setTimeout(() => {
    document.getElementById('authPage').classList.add('hidden');
    document.getElementById('appShell').classList.remove('hidden');
    initApp();
  }, 350);
}

function doLogout() {
  localStorage.removeItem('enginex_session');
  document.getElementById('appShell').classList.add('hidden');
  document.getElementById('authPage').classList.remove('hidden');
  document.getElementById('authPage').style.opacity = '1';
  currentUser = null; chatHistory = [];
}

