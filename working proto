// ══════════════════════════════════════════ CLAUDE API HELPER
async function callClaude(systemPrompt, userMessage, maxTokens = 1200) {
  if (!apiKey) throw new Error('NO_KEY');
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': apiKey,
      'anthropic-version': '2023-06-01',
      'anthropic-dangerous-direct-browser-access': 'true',
    },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: maxTokens,
      system: systemPrompt,
      messages: [{ role: 'user', content: userMessage }],
    }),
  });
  const data = await res.json();
  if (data.error) throw new Error(data.error.message);
  return data.content.map(b => b.text || '').join('');
}

// ══════════════════════════════════════════ AI QUESTION GENERATOR
async function generateQuestions(subjId, difficulty) {
  const subjNm = SUBJECTS.find(s => s.id === subjId)?.nm || subjId;

  const system = `You are an expert engineering quiz generator.
Output ONLY valid JSON — no markdown fences, no explanation, nothing else.
Schema: [{"q":"question","opts":["A","B","C","D"],"c":0,"exp":"brief explanation"},...]
Rules:
- Exactly 10 questions
- "c" is the 0-based index of the correct answer
- Questions must be CS/Engineering level, not trivial
- For ${difficulty} difficulty: ${difficulty==='Easy'?'basic recall/syntax':difficulty==='Medium'?'applied concepts, edge cases, code snippets':' deep tricky edge cases, complexity analysis, and debugging scenarios'}
- Code snippet questions MUST use backtick-wrapped code inside the "q" field
- Explanation must be concise (1 sentence)`;

  const raw = await callClaude(system, `Generate 10 ${difficulty} MCQ questions for the topic: ${subjNm}`);

  // Strip any accidental markdown fences and parse
  const clean = raw.replace(/```json|```/g, '').trim();
  const arr = JSON.parse(clean);
  if (!Array.isArray(arr) || arr.length < 5) throw new Error('Bad format from AI');
  return arr.slice(0, 10);
}

// ══════════════════════════════════════════ AI QUIZ INSIGHT
async function generateQuizInsight(subjNm, score, wrongTopics) {
  if (!apiKey) return null;
  try {
    const system = `You are a concise engineering tutor giving post-quiz feedback. 2-3 sentences max. Be direct and encouraging.`;
    const msg = `Student scored ${score}/10 on ${subjNm} (${selectedDiff}). Wrong questions: ${wrongTopics.join(', ')||'none'}. Give a short recommendation.`;
    return await callClaude(system, msg, 200);
  } catch { return null; }
}

