function buildQuizSubjects(){
  document.getElementById('subjGrid').innerHTML=SUBJECTS.map(s=>`
    <div class="subj-card ${s.id===selSubj?'sel':''}" onclick="setSubj(this,'${s.id}')">
      <div class="subj-card-ico">${s.ico}</div>
      <div class="subj-card-name">${s.nm}</div>
      <div class="subj-card-count">${s.topics} topics</div>
    </div>`).join('');
}
function setSubj(el,id){
  document.querySelectorAll('.subj-card').forEach(c=>c.classList.remove('sel'));
  el.classList.add('sel');selSubj=id;
}
function setDiff(d,btn){
  document.querySelectorAll('.diff-btn').forEach(b=>{b.classList.remove('active');b.textContent=b.textContent.replace(' ✓','');});
  btn.classList.add('active');btn.textContent=d+' ✓';selDiff=d;
}
function setMode(m,el){
  document.querySelectorAll('.mode-card').forEach(c=>c.classList.remove('sel'));
  el.classList.add('sel');selMode=m;
}

async function callGroqForQuiz(subjNm,diff,total){
  const sys=`You are an expert engineering quiz generator.
Output ONLY valid JSON array — no markdown, no explanation.
Schema: [{"q":"question text","opts":["A","B","C","D"],"c":0,"exp":"one sentence explanation"},...]
Rules:
- Exactly ${total} questions
- "c" is the 0-based correct answer index
- Difficulty ${diff}: ${diff==='Easy'?'basic recall, syntax':diff==='Medium'?'applied concepts, edge cases':' tricky edge cases, complexity analysis, debugging'}
- Backtick-wrapped code in "q" field for code questions
- Explanations: 1 sentence max`;
  const raw=await callGroq(sys,`Generate ${total} ${diff} MCQ questions for: ${subjNm}`);
  const clean=raw.replace(/```json|```/g,'').trim();
  const arr=JSON.parse(clean);
  if(!Array.isArray(arr)||arr.length<3)throw new Error('Bad format');
  return arr.slice(0,total);
}

async function callGroq(sysPrompt,userMsg,maxTok=1400){
  if(!apiKey)throw new Error('NO_KEY');
  const res=await fetch('https://api.groq.com/openai/v1/chat/completions',{
    method:'POST',
    headers:{'Content-Type':'application/json','Authorization':`Bearer ${apiKey}`},
    body:JSON.stringify({model:'llama-3.3-70b-versatile',max_tokens:maxTok,
      messages:[{role:'system',content:sysPrompt},{role:'user',content:userMsg}]}),
  });
  const data=await res.json();
  if(data.error)throw new Error(data.error.message||JSON.stringify(data.error));
  return data.choices[0].message.content;
}

async function startQuiz(){
  const totalMap={standard:10,speed:15,deep:5};
  const timerMap={Easy:45,Medium:35,Hard:25};
  const total=totalMap[selMode];
  activeQuiz={subj:selSubj,diff:selDiff,mode:selMode,q:0,score:0,total,
    timer:null,timerVal:selMode==='speed'?20:timerMap[selDiff],
    answered:false,wrongList:[]};
  
  document.getElementById('quizSetup').classList.add('hidden');
  document.getElementById('quizActive').classList.remove('hidden');
  document.getElementById('quizResults').classList.add('hidden');
  document.getElementById('qTotal').textContent=total;
  document.getElementById('qText').innerHTML=`
    <div style="text-align:center;padding:28px 0;">
      <div class="typing-anim" style="display:flex;justify-content:center;margin-bottom:14px;"><span></span><span></span><span></span></div>
      <div style="color:var(--muted2);font-size:12.5px;">
        ${apiKey?`⚡ Groq AI generating <strong>${SUBJECTS.find(s=>s.id===selSubj)?.nm}</strong> questions (${selDiff})…`:'📚 Loading offline questions…'}
      </div>
    </div>`;
  document.getElementById('qTags').innerHTML='';
  document.getElementById('qOpts').innerHTML='';
  document.getElementById('btnNext').disabled=true;
  
  try{
    if(apiKey){generatedQ=await callGroqForQuiz(SUBJECTS.find(s=>s.id===selSubj)?.nm||selSubj,selDiff,total);}
    else{
      const bank=FALLBACK[selSubj]||FALLBACK.dsa;
      const extended=[...bank];
      while(extended.length<total)extended.push(...bank);
      generatedQ=extended.sort(()=>Math.random()-.5).slice(0,total);
    }
    renderQuestion();
  }catch(err){
    console.warn('Quiz gen failed:',err.message);
    const bank=FALLBACK[selSubj]||FALLBACK.dsa;
    const ext=[...bank];while(ext.length<total)ext.push(...bank);
    generatedQ=ext.sort(()=>Math.random()-.5).slice(0,total);
    showToast('Using offline questions (API error).','error');
    renderQuestion();
  }
}

function renderQuestion(){
  const q=generatedQ[activeQuiz.q];
  activeQuiz.answered=false;
  document.getElementById('qNum').textContent=activeQuiz.q+1;
  document.getElementById('qProgressFill').style.width=((activeQuiz.q+1)/activeQuiz.total*100)+'%';
  document.getElementById('btnNext').disabled=true;
  document.getElementById('qFeedback').textContent='';
  
  const s=SUBJECTS.find(s=>s.id===activeQuiz.subj)||SUBJECTS[4];
  document.getElementById('qTags').innerHTML=`
    <span class="tag tag-cyan">${s.ico} ${s.nm}</span>
    <span class="tag tag-purple">${selDiff}</span>
    ${apiKey?'<span class="tag tag-green">⚡ AI Generated</span>':''}
    <span class="tag" style="background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.15);color:var(--yellow)">${activeQuiz.mode}</span>`;
  
  document.getElementById('qText').innerHTML=(q.q||'').replace(/`([^`]+)`/g,
    '<code style="font-family:var(--mono);background:rgba(0,212,255,.08);padding:2px 6px;border-radius:4px;font-size:13px;color:var(--cyan)">$1</code>');
  
  const ltrs=['A','B','C','D'];
  document.getElementById('qOpts').innerHTML=(q.opts||[]).map((o,i)=>`
    <div class="q-option" onclick="pickAnswer(this,${i})">
      <div class="q-opt-letter">${ltrs[i]}</div>
      ${String(o).replace(/`([^`]+)`/g,'<code style="font-family:var(--mono);background:rgba(255,255,255,.07);padding:1px 5px;border-radius:3px">$1</code>')}
    </div>`).join('');
  
  clearInterval(activeQuiz.timer);
  if(activeQuiz.mode!=='deep'){
    document.getElementById('qTimer').textContent=`⏱ ${activeQuiz.timerVal}s`;
    let tv=activeQuiz.mode==='speed'?20:(selDiff==='Easy'?45:selDiff==='Medium'?35:25);
    document.getElementById('qTimer').textContent=`⏱ ${tv}s`;
    activeQuiz.timer=setInterval(()=>{
      tv--;
      document.getElementById('qTimer').textContent=`⏱ ${tv}s`;
      if(tv<=0){clearInterval(activeQuiz.timer);if(!activeQuiz.answered)timeOutQ();}
    },1000);
  }else{
    document.getElementById('qTimer').textContent='⏱ ∞';
  }
}

function pickAnswer(el,idx){
  if(activeQuiz.answered)return;
  activeQuiz.answered=true;
  clearInterval(activeQuiz.timer);
  const correct=generatedQ[activeQuiz.q].c;
  const exp=generatedQ[activeQuiz.q].exp||'';
  document.querySelectorAll('.q-option').forEach((o,i)=>{
    if(i===correct)o.classList.add('correct');
    else if(i===idx&&i!==correct)o.classList.add('wrong');
  });
  if(idx===correct){
    activeQuiz.score++;
    document.getElementById('qFeedback').innerHTML=`<span style="color:var(--green)">✓ Correct! ${exp}</span>`;
  }else{
    activeQuiz.wrongList.push((generatedQ[activeQuiz.q].q||'').slice(0,50));
    document.getElementById('qFeedback').innerHTML=`<span style="color:var(--red)">✗ Wrong. ${exp}</span>`;
  }
  document.getElementById('btnNext').disabled=false;
}

function timeOutQ(){
  activeQuiz.answered=true;
  const correct=generatedQ[activeQuiz.q].c;
  document.querySelectorAll('.q-option')[correct]?.classList.add('correct');
  activeQuiz.wrongList.push((generatedQ[activeQuiz.q].q||'').slice(0,50));
  document.getElementById('qFeedback').innerHTML=`<span style="color:var(--yellow)">⏱ Time's up! Correct: ${generatedQ[activeQuiz.q].opts[correct]}</span>`;
  document.getElementById('btnNext').disabled=false;
}

function nextQuestion(){
  activeQuiz.q++;
  if(activeQuiz.q>=activeQuiz.total)finishQuiz();
  else renderQuestion();
}

async function finishQuiz(){
  clearInterval(activeQuiz.timer);
  document.getElementById('quizActive').classList.add('hidden');
  document.getElementById('quizResults').classList.remove('hidden');
  
  const pct=Math.round(activeQuiz.score/activeQuiz.total*100);
  const xp=activeQuiz.score*20;
  document.getElementById('resultPct').textContent=pct+'%';
  document.getElementById('resultRing').style.setProperty('--fill',(pct*3.6)+'deg');
  document.getElementById('resCorrect').textContent=activeQuiz.score;
  document.getElementById('resWrong').textContent=activeQuiz.total-activeQuiz.score;
  document.getElementById('resXP').textContent='+'+xp;
  
  const msgs=[[80,'Outstanding! 🏆','Top-tier performance! Push to the next difficulty level.'],[60,'Good Work! 👍','Solid effort. Review your wrong answers carefully.'],[0,'Keep Going! 💪','Every attempt builds knowledge. Try again!']];
  for(const[min,t,m]of msgs){if(pct>=min){document.getElementById('resultTitle').textContent=t;document.getElementById('resultMsg').textContent=m;break;}}
  
  // Persist
  const users=JSON.parse(localStorage.getItem('ex_users')||'{}');
  if(users[currentUser.email]){
    const ud=users[currentUser.email].data;
    ud.tests=(ud.tests||0)+1; ud.xp=(ud.xp||0)+xp;
    const prev=(ud.avgScore||0)*(ud.tests-1);
    ud.avgScore=Math.round((prev+pct)/ud.tests);
    if(!ud.subjectScores)ud.subjectScores={};
    if(!ud.subjectScores[activeQuiz.subj])ud.subjectScores[activeQuiz.subj]=[];
    ud.subjectScores[activeQuiz.subj].push(pct);
    if(ud.subjectScores[activeQuiz.subj].length>20)ud.subjectScores[activeQuiz.subj].shift();
    const sNm=SUBJECTS.find(s=>s.id===activeQuiz.subj)?.nm||activeQuiz.subj;
    ud.activity.unshift({subj:`${sNm} (${selDiff})`,score:pct,date:'Just now',type:'Test'});
    if(ud.activity.length>25)ud.activity.pop();
    const dayIdx=[6,0,1,2,3,4,5][new Date().getDay()];
    ud.weeklyMins=ud.weeklyMins||[0,0,0,0,0,0,0];
    ud.weeklyMins[dayIdx]=(ud.weeklyMins[dayIdx]||0)+10;
    localStorage.setItem('ex_users',JSON.stringify(users));
    currentUser=users[currentUser.email];
    appStats={tests:ud.tests,xp:ud.xp,avgScore:ud.avgScore,streak:ud.streak||1};
    document.getElementById('sbRole').textContent=`Level ${lvl(ud.xp)} · ${currentUser.branch.split(' ')[0]}`;
  }
  
  // AI insight
  if(apiKey&&activeQuiz.wrongList.length>0){
    const box=document.getElementById('aiInsightBox');
    box.style.display='block';
    box.innerHTML='<div class="typing-anim" style="display:flex"><span></span><span></span><span></span></div>';
    try{
      const sNm=SUBJECTS.find(s=>s.id===activeQuiz.subj)?.nm||activeQuiz.subj;
      const insight=await callGroq(
        'You are a concise engineering tutor. Give 2-3 sentence post-quiz feedback. Be direct and constructive.',
        `Student scored ${activeQuiz.score}/${activeQuiz.total} on ${sNm} (${selDiff}). Wrong: ${activeQuiz.wrongList.slice(0,3).join('; ')}.`,
        200);
      box.innerHTML=`<strong>✦ AI Insight</strong><br>${insight.replace(/\n/g,'<br>')}`;
    }catch{box.style.display='none';}
  }
}

function resetQuiz(){
  document.getElementById('quizResults').classList.add('hidden');
  document.getElementById('quizSetup').classList.remove('hidden');
  document.getElementById('aiInsightBox').style.display='none';
  buildQuizSubjects();
  refreshApp();
}

