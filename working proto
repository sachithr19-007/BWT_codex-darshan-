  scrollChat();

  let reply;
  if (apiKey) {
    try {
      chatHistory.push({ role: 'user', content: txt });
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': apiKey,
          'anthropic-version': '2023-06-01',
          'anthropic-dangerous-direct-browser-access': 'true',
        },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          system: `You are EngineX AI — an expert engineering tutor for CS & Engineering students.
Specialities: Python, Java, JavaScript, C++, DSA, DBMS, Operating Systems, Computer Networks, Discrete Math, System Design.
Format: Use **bold** for key terms. Use triple-backtick code blocks with language name. Be concise, practical, exam-aware.
Always give a working code example when relevant. Address the student by name if mentioned.`,
          messages: chatHistory,
        }),
      });
      const data = await res.json();
      if (data.error) throw new Error(data.error.message);
      reply = data.content[0].text;
      chatHistory.push({ role: 'assistant', content: reply });
    } catch (err) {
      reply = `⚠️ **API Error:** ${err.message}\n\nCheck your API key in Settings or the sidebar panel.`;
    }
  } else {
    reply = getDemoResponse(txt);
  }

  document.getElementById(tid)?.remove();
  addChatMsg('ai', formatMsg(reply));
  document.getElementById('sendBtn').disabled = false;

  const xp = parseInt(document.getElementById('xpCount').textContent.replace('+', '')) + 15;
  document.getElementById('xpCount').textContent = '+' + xp;

