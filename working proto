        <span class="tag tag-purple">${rd.totalTopics} Resources</span>
      </div>
    </div>
    <div class="rm-overall-progress">
      <div class="rm-overall-pct">${pct}%</div>
      <div class="rm-overall-label">Complete</div>
      <div class="rm-overall-bar"><div class="rm-overall-fill" style="width:0%;background:${rd.color}" data-w="${pct}%"></div></div>
      <div style="font-family:var(--mono);font-size:9.5px;color:var(--muted2);margin-top:4px">${doneTopics}/${totalTopics} topics</div>
    </div>
  </div>
  <div class="rm-track">`;
  
  phases.forEach((p,i)=>{
    const cls=p.done?'done-phase':p.active?'current-phase':'locked-phase';
    const dotCls=p.done?'done':p.active?'current':'locked';
    html+=`<div class="rm-phase-block">
      <div class="rm-phase-dot ${dotCls}" style="${p.done?`background:${rd.color};border-color:${rd.color}`:p.active?`border-color:${rd.color};color:${rd.color}`:''}">${i+1}</div>
      <div class="rm-phase-card ${cls}">
        <div class="rm-phase-card-header">
          <div class="rm-phase-title">${p.title}</div>
          <div class="rm-phase-status">
            ${p.done?`<span class="tag tag-green">✓ Completed</span>`:p.active?`<span class="tag tag-cyan">▶ In Progress</span>`:`<span class="tag" style="background:rgba(255,255,255,.03);border:1px solid var(--border);color:var(--muted)">🔒 Locked</span>`}
          </div>
        </div>
        <div class="rm-topics-wrap">
          ${p.topics.map(t=>`<span class="rm-topic-chip ${p.done?'rm-topic-done':p.active?'rm-topic-active':'rm-topic-locked'}">${t}</span>`).join('')}
        </div>
        <div class="rm-resources">
          <div class="rm-res-title">📚 Resources</div>
          <div class="rm-res-links">
            ${p.resources.map(r=>`<span class="rm-res-link">${r}</span>`).join('')}
          </div>
        </div>
      </div>
    </div>`;
  });
  html+='</div>';
  document.getElementById('rmContent').innerHTML=html;
  setTimeout(()=>document.querySelectorAll('.rm-overall-fill').forEach(e=>e.style.width=e.dataset.w),120);
}

