function chatKey(e) {
  if(e.key==='Enter' && !e.shiftKey){ e.preventDefault(); sendMsg(); }
}

async function sendMsg() {
  const inp = document.getElementById('chatInp');
  const txt = inp.value.trim();
  if(!txt) return;
  inp.value = '';
  addMsg('user', txt);
  document.getElementById('sendBtn').disabled = true;
  const cnt = parseInt(document.getElementById('msgCount').textContent) + 1;
  document.getElementById('msgCount').textContent = cnt;

  // Typing
  const tid = 'typing_'+Date.now();
  document.getElementById('chatMsgs').insertAdjacentHTML('beforeend',
    `<div class="msg ai" id="${tid}"><div class="msg-lbl">AI Tutor</div><div class="msg-bub"><div class="typing-dots"><span></span><span></span><span></span></div></div></div>`);
  scrollChat();

  let reply;
  if(apiKey) {
    try {
      chatHistory.push({role:'user',content:txt});
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method:'POST',
        headers:{'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
        body:JSON.stringify({
          model:'claude-sonnet-4-20250514',
          max_tokens:1000,
          system:`You are EngineX AI — a brilliant engineering tutor for CS/Engineering students. 
You help with Python, Java, JavaScript, C++, DSA, DBMS, Operating Systems, Computer Networks, and Discrete Mathematics.
Format code blocks with triple backticks and the language name.
Be concise, use bullet points, and always give a practical code example when relevant.
Address the student directly and encouragingly.`,
          messages: chatHistory
        })
      });
      const data = await res.json();
      if(data.error) throw new Error(data.error.message);
      reply = data.content[0].text;
      chatHistory.push({role:'assistant',content:reply});
    } catch(err) {
      reply = `⚠️ API Error: ${err.message}. Check your API key in Settings.`;
    }
  } else {
    reply = getDemoResponse(txt);
  }

  document.getElementById(tid)?.remove();
  addMsg('ai', formatAIMsg(reply));
  document.getElementById('sendBtn').disabled = false;

  const xp = parseInt(document.getElementById('xpCount').textContent.replace('+','')) + 15;
  document.getElementById('xpCount').textContent = '+'+xp;
  scrollChat();
}

function formatAIMsg(text) {
  // Format code blocks
  text = text.replace(/```(\w+)?\n([\s\S]*?)```/g, (_, lang, code) =>
    `<div class="code-lang">${lang||'code'}</div><pre><code>${escHtml(code.trim())}</code></pre>`);
  text = text.replace(/`([^`]+)`/g, '<code style="font-family:var(--mono);background:rgba(0,229,255,.08);padding:1px 5px;border-radius:3px;color:var(--cyan)">$1</code>');
  text = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  text = text.replace(/\n/g, '<br>');
  return text;
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function addMsg(role, html) {
  const el = document.createElement('div');
  el.className = `msg ${role}`;
  el.innerHTML = `<div class="msg-lbl">${role==='ai'?'AI Tutor':'You'}</div><div class="msg-bub">${html}</div>`;
  document.getElementById('chatMsgs').appendChild(el);
  scrollChat();
}

function scrollChat() {
  const m = document.getElementById('chatMsgs');
  m.scrollTop = m.scrollHeight;
}

function askTopic(q) {
  document.getElementById('chatInp').value = q;
  sendMsg();
  goPanel('tutor', document.querySelectorAll('.nav-item')[1]);
}

function getDemoResponse(q) {
  const ql = q.toLowerCase();
  if(ql.includes('python') || ql.includes('decorator')) return `**Python Decorators** 🐍\n\nDecorators wrap a function to add behaviour without modifying it.\n\n\`\`\`python\ndef timer(func):\n    import time\n    def wrapper(*args, **kwargs):\n        start = time.time()\n        result = func(*args, **kwargs)\n        print(f"Ran in {time.time()-start:.4f}s")\n        return result\n    return wrapper\n\n@timer\ndef slow_function():\n    time.sleep(0.5)\n\nslow_function()  # Ran in 0.5001s\`\`\`\n\nKey points:\n• A decorator is a **higher-order function**\n• \`@decorator\` is syntactic sugar for \`func = decorator(func)\`\n• Common uses: logging, authentication, caching\n\n> 💡 Add your Anthropic API key in Settings for real-time answers!`;
  if(ql.includes('bigo')||ql.includes('complexity')||ql.includes('o(n)')) return `**Big O Notation** 🌲\n\n| Notation | Name | Example |\n|---|---|---|\n| O(1) | Constant | Array index access |\n| O(log n) | Logarithmic | Binary Search |\n| O(n) | Linear | Linear Search |\n| O(n log n) | Linearithmic | Merge Sort |\n| O(n²) | Quadratic | Bubble Sort |\n\n\`\`\`python\n# O(n²) - Nested loops\nfor i in range(n):\n    for j in range(n):  # Bad for large n!\n        ...\n\n# O(n log n) - Merge Sort\ndef merge_sort(arr):\n    if len(arr) <= 1: return arr\n    mid = len(arr) // 2\n    L = merge_sort(arr[:mid])\n    R = merge_sort(arr[mid:])\n    return merge(L, R)\`\`\`\n\n> 💡 Add your API key for live AI responses!`;
  if(ql.includes('sql')||ql.includes('join')||ql.includes('dbms')) return `**SQL JOINs** 🗄️\n\n\`\`\`sql\n-- INNER JOIN: only matching rows\nSELECT e.name, d.dept_name\nFROM employees e\nINNER JOIN departments d ON e.dept_id = d.id;\n\n-- LEFT JOIN: all from left table\nSELECT e.name, d.dept_name\nFROM employees e\nLEFT JOIN departments d ON e.dept_id = d.id;\n\n-- GROUP BY with aggregate\nSELECT dept_id, COUNT(*) as count, AVG(salary)\nFROM employees\nGROUP BY dept_id\nHAVING COUNT(*) > 5;\`\`\`\n\nTypes:\n• **INNER** — matching rows only\n• **LEFT** — all left + matching right\n• **RIGHT** — all right + matching left\n• **FULL OUTER** — all rows from both\n\n> 💡 Add your API key for live responses!`;
  if(ql.includes('java')||ql.includes('oop')||ql.includes('polymorphism')) return `**OOP Pillars in Java** ☕\n\n\`\`\`java\n// Encapsulation\nclass BankAccount {\n    private double balance; // hidden!\n    public void deposit(double amt) {\n        if(amt > 0) balance += amt;\n    }\n}\n\n// Inheritance + Polymorphism\nabstract class Shape {\n    abstract double area();\n}\nclass Circle extends Shape {\n    double r;\n    Circle(double r){ this.r = r; }\n    @Override\n    double area(){ return Math.PI * r * r; }\n}\`\`\`\n\n4 Pillars: **Encapsulation** · **Abstraction** · **Inheritance** · **Polymorphism**\n\n> 💡 Add your Anthropic API key for live Claude responses!`;
  return `Great question! 👾 Here's what you need to know:\n\n**Key Concepts:**\n• This is a core engineering topic covered in interviews\n• Understanding fundamentals beats memorizing solutions\n• Practice implementation regularly\n\n> 💡 **Add your Anthropic API key** in Settings or the sidebar panel to get real Claude AI responses with detailed code examples tailored exactly to your question!`;
}

// ══════════════════════════════════════════ QUIZ
let selectedSubj = 'dsa';
let selectedDiff = 'Medium';
let shuffledQ = [];

function pickSubj(el, id) {
  document.querySelectorAll('.qsubj-card').forEach(c => c.classList.remove('sel'));
  el.classList.add('sel');
  selectedSubj = id;
}

function pickDiff(btn, d) {
  document.querySelectorAll('.diff-btn').forEach(b => {
    b.className = 'diff-btn';
    b.textContent = b.textContent.replace(' ✓','');
  });
  const cls = d==='Easy'?'sel-e':d==='Medium'?'sel-m':'sel-h';
  btn.className = `diff-btn ${cls}`;
  btn.textContent = d + ' ✓';
  selectedDiff = d;
}

function startQuiz() {
  quizState = { subj:selectedSubj, diff:selectedDiff, q:0, score:0, timer:null, timerVal:35, answered:false };
  shuffledQ = [...(QUIZ_BANK[selectedSubj]||QUIZ_BANK.dsa)].sort(()=>Math.random()-.5).slice(0,10);
  document.getElementById('quizPick').classList.add('hidden');
  document.getElementById('quizActive').classList.remove('hidden');
  renderQ();
}

function renderQ() {
  const q = shuffledQ[quizState.q];
  quizState.answered = false;
  document.getElementById('qNum').textContent = quizState.q+1;
  document.getElementById('qPF').style.width = ((quizState.q+1)/10*100)+'%';
  document.getElementById('btnNext').disabled = true;
  document.getElementById('qFb').textContent = '';

  const subj = SUBJECTS.find(s=>s.id===quizState.subj)||SUBJECTS[4];
  document.getElementById('qPills').innerHTML = `
    <span class="lang-pill" style="background:rgba(0,229,255,.08);border-color:rgba(0,229,255,.25);color:var(--cyan)">${subj.ico} ${subj.nm}</span>
    <span class="lang-pill" style="background:rgba(189,147,249,.08);border-color:rgba(189,147,249,.25);color:var(--purple)">${selectedDiff}</span>`;

  document.getElementById('qText').innerHTML = q.q.replace(/`([^`]+)`/g,'<code>$1</code>');
  const ltrs = ['A','B','C','D'];
  document.getElementById('qOpts').innerHTML = q.opts.map((o,i) =>
    `<div class="q-opt" onclick="pickAns(this,${i})">
      <div class="q-opt-ltr">${ltrs[i]}</div>
      ${o.replace(/`([^`]+)`/g,'<code>$1</code>')}
    </div>`).join('');

  clearInterval(quizState.timer);
  quizState.timerVal = selectedDiff==='Easy'?45:selectedDiff==='Medium'?35:25;
  document.getElementById('qTimer').textContent = `⏱ ${quizState.timerVal}s`;
  quizState.timer = setInterval(() => {
    quizState.timerVal--;
    document.getElementById('qTimer').textContent = `⏱ ${quizState.timerVal}s`;
    if(quizState.timerVal<=0){ clearInterval(quizState.timer); if(!quizState.answered) timeUp(); }
  }, 1000);
}

function pickAns(el, idx) {
  if(quizState.answered) return;
  quizState.answered = true;
  clearInterval(quizState.timer);
  const correct = shuffledQ[quizState.q].c;
  const exp = shuffledQ[quizState.q].exp;
  document.querySelectorAll('.q-opt').forEach((o,i) => {
    if(i===correct) o.classList.add('correct');
    else if(i===idx && i!==correct) o.classList.add('wrong');
  });
  if(idx===correct){ quizState.score++; document.getElementById('qFb').innerHTML = `<span style="color:var(--green)">✓ Correct! ${exp}</span>`; }
  else document.getElementById('qFb').innerHTML = `<span style="color:var(--red)">✗ Wrong. ${exp}</span>`;
  document.getElementById('btnNext').disabled = false;
}

function timeUp() {
  quizState.answered = true;
  const correct = shuffledQ[quizState.q].c;
  document.querySelectorAll('.q-opt')[correct]?.classList.add('correct');
  document.getElementById('qFb').innerHTML = `<span style="color:var(--yellow)">⏱ Time's up! Correct: ${shuffledQ[quizState.q].opts[correct]}</span>`;
  document.getElementById('btnNext').disabled = false;
}

function nextQ() {
  quizState.q++;
  if(quizState.q >= 10) showRes();
  else renderQ();
}

function showRes() {
  clearInterval(quizState.timer);
  document.getElementById('quizActive').classList.add('hidden');
  document.getElementById('quizRes').classList.remove('hidden');
  const pct = Math.round(quizState.score/10*100);
  const xp = quizState.score * 20;
  document.getElementById('resPct').textContent = pct+'%';
  document.getElementById('resRing').style.setProperty('--sdeg', (pct*3.6)+'deg');
  document.getElementById('resC').textContent = quizState.score;
  document.getElementById('resW').textContent = 10-quizState.score;
  document.getElementById('resXP').textContent = '+'+xp;
  const msgs = [[80,'Outstanding! 🏆','Top-tier performance. Keep going!'],
                [60,'Good Work! 👍','Review the topics you missed.'],
                [0,'Keep Practicing! 💪','Every attempt builds knowledge.']];
  for(const [min,title,msg] of msgs){
    if(pct>=min){ document.getElementById('resTitle').textContent=title; document.getElementById('resMsg').textContent=msg; break; }
  }
  // Save to user data
  const users = JSON.parse(localStorage.getItem('enginex_users')||'{}');
  if(users[currentUser.email]) {
    users[currentUser.email].data.tests++;
    users[currentUser.email].data.xp += xp;
    const scores = users[currentUser.email].data.activity;
    const subj = SUBJECTS.find(s=>s.id===quizState.subj);
    scores.unshift({subj:`${subj.nm} Mock Test`,score:pct,date:'Just now',type:'Test'});
    localStorage.setItem('enginex_users', JSON.stringify(users));
  }
}

function resetQuiz() {
  document.getElementById('quizRes').classList.add('hidden');
  document.getElementById('quizPick').classList.remove('hidden');
}

// ══════════════════════════════════════════ ROADMAP
let activeRoadmapLang = 'python';

function initRoadmap() {
  const ids = Object.keys(ROADMAPS);
  document.getElementById('langTabs').innerHTML = ids.map(id => `
    <button class="lang-tab ${id===activeRoadmapLang?'active':''}" onclick="switchRoadmap('${id}',this)">${ROADMAPS[id].label}</button>
  `).join('') + SUBJECTS.filter(s=>!ids.includes(s.id)).map(s=>
    `<button class="lang-tab" style="opacity:.5">${s.ico} ${s.nm}</button>`).join('');
  renderRoadmap();
}

function switchRoadmap(id, btn) {
  activeRoadmapLang = id;
  document.querySelectorAll('.lang-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderRoadmap();
}

function renderRoadmap() {
  const rm = ROADMAPS[activeRoadmapLang];
  if(!rm) { document.getElementById('roadmapContent').innerHTML = '<div style="color:var(--muted2);text-align:center;padding:40px">Roadmap coming soon! 🚧</div>'; return; }
  let html = `<div class="roadmap-track">`;
  rm.phases.forEach((p, i) => {
    const dotCls = p.done ? 'done' : '';
    html += `<div class="rm-phase" style="position:relative">
      <div class="rm-dot ${dotCls}" style="${p.done?`background:${rm.color};border-color:${rm.color}`:p.active?`border-color:${rm.color};color:${rm.color}`:''}">${i+1}</div>
      <div class="rm-header">
        <div class="rm-phase-title">${p.n}</div>
        ${p.done?`<span class="lang-pill" style="background:rgba(57,255,144,.08);border-color:rgba(57,255,144,.2);color:var(--green);font-size:10px">✓ Done</span>`:p.active?`<span class="lang-pill" style="background:rgba(0,229,255,.08);border-color:rgba(0,229,255,.2);color:var(--cyan);font-size:10px">In Progress</span>`:''}
      </div>
      <div class="rm-topics">
        ${p.topics.map(t => `<span class="rm-topic ${p.done?'done-t':p.active?'active-t':'locked-t'}">${t}</span>`).join('')}
      </div>
    </div>`;
  });
  html += '</div>';
  document.getElementById('roadmapContent').innerHTML = html;
}

// ══════════════════════════════════════════ PROGRESS
function initProgress() {
  const hrs = [30,65,45,80,55,70,35];
  document.getElementById('weekChart').innerHTML = hrs.map((h,i) =>
    `<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:3px">
      <div style="font-family:var(--mono);font-size:9px;color:var(--muted2)">${h}m</div>
      <div style="width:100%;height:${h}%;background:${i===2?'var(--cyan)':'rgba(0,229,255,.15)'};border-radius:3px;transition:height .5s"></div>
    </div>`).join('');

  const hist = [{s:'DSA Mock Test',sc:88,d:'Today'},{s:'Python Functions',sc:76,d:'Yesterday'},{s:'DBMS SQL Joins',sc:68,d:'2 days ago'},{s:'OS - Scheduling',sc:92,d:'3 days ago'}];
  document.getElementById('scoreHist').innerHTML = hist.map(h => {
    const c = h.sc>=80?'var(--green)':h.sc>=60?'var(--yellow)':'var(--red)';
    return `<div style="display:flex;align-items:center;justify-content:space-between;padding:9px;background:rgba(255,255,255,.02);border-radius:8px;margin-bottom:7px">
      <div><div style="font-size:13px;font-weight:600">${h.s}</div><div style="font-family:var(--mono);font-size:10px;color:var(--muted)">${h.d}</div></div>
      <div style="font-family:var(--mono);font-size:15px;font-weight:700;color:${c}">${h.sc}%</div>
    </div>`;
  }).join('');

  const pcts={python:75,javascript:58,java:45,cpp:38,dsa:82,dbms:60,os:50,cn:42};
  document.getElementById('detailProg').innerHTML = SUBJECTS.map(s => {
    const p = pcts[s.id]||50;
    return `<div style="margin-bottom:14px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:5px">
        <div style="display:flex;align-items:center;gap:8px"><span>${s.ico}</span><span style="font-size:13px;font-weight:600">${s.nm}</span></div>
        <span style="font-family:var(--mono);font-size:13px;font-weight:700;color:${s.color}">${p}%</span>
      </div>
      <div style="height:7px;background:rgba(255,255,255,.06);border-radius:4px;overflow:hidden">
        <div style="width:${p}%;height:100%;background:${s.color};border-radius:4px;transition:width 1s ease"></div>
      </div>
    </div>`;
  }).join('');
}

