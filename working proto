<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EngineX — Engineering Learning Platform</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #080c10;
  --surface: #0d1117;
  --card: #161b22;
  --card2: #1c2230;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.12);
  --cyan: #00e5ff;
  --green: #39ff90;
  --orange: #ff7b35;
  --purple: #bd93f9;
  --pink: #ff6eb4;
  --yellow: #f1fa8c;
  --red: #ff5555;
  --text: #e6edf3;
  --muted: #484f58;
  --muted2: #8b949e;
  --mono: 'JetBrains Mono', monospace;
  --sans: 'Manrope', sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}

/* ── SCANLINES OVERLAY */
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,229,255,0.012) 2px,rgba(0,229,255,0.012) 4px);pointer-events:none;z-index:9998;}

/* ── UTILITIES */
.hidden{display:none!important;}
.mono{font-family:var(--mono);}

/* ══════════════════════════════════════════ AUTH */
#authPage{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;position:relative;}
.auth-bg{position:fixed;inset:0;z-index:0;
  background:radial-gradient(ellipse 70% 60% at 10% 50%,rgba(0,229,255,.08) 0,transparent 60%),
             radial-gradient(ellipse 50% 50% at 90% 20%,rgba(57,255,144,.06) 0,transparent 55%),
             radial-gradient(ellipse 40% 40% at 50% 90%,rgba(189,147,249,.07) 0,transparent 55%);}
.auth-grid{position:fixed;inset:0;z-index:0;background-image:linear-gradient(rgba(0,229,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(0,229,255,.03) 1px,transparent 1px);background-size:32px 32px;}

.auth-wrap{position:relative;z-index:1;display:grid;grid-template-columns:1fr 420px;gap:80px;align-items:center;max-width:980px;width:100%;}

.auth-hero{}
.brand{display:inline-flex;align-items:center;gap:10px;margin-bottom:44px;}
.brand-icon{width:42px;height:42px;background:var(--cyan);border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-weight:700;font-size:16px;color:var(--bg);}
.brand-name{font-family:var(--mono);font-size:18px;font-weight:700;color:var(--text);}
.brand-name span{color:var(--cyan);}

.auth-hero h1{font-size:clamp(2.2rem,4.5vw,3.4rem);font-weight:800;letter-spacing:-.03em;line-height:1.05;margin-bottom:18px;}
.auth-hero h1 .hl{background:linear-gradient(90deg,var(--cyan),var(--green));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.auth-hero p{color:var(--muted2);font-size:14px;line-height:1.75;max-width:400px;margin-bottom:32px;}

.lang-pills{display:flex;flex-wrap:wrap;gap:8px;}
.lang-pill{padding:5px 12px;border-radius:6px;font-family:var(--mono);font-size:11px;font-weight:600;border:1px solid;cursor:default;}
.lp-py{background:rgba(57,255,144,.08);border-color:rgba(57,255,144,.25);color:var(--green);}
.lp-js{background:rgba(241,250,140,.08);border-color:rgba(241,250,140,.25);color:var(--yellow);}
.lp-java{background:rgba(255,123,53,.08);border-color:rgba(255,123,53,.25);color:var(--orange);}
.lp-cpp{background:rgba(0,229,255,.08);border-color:rgba(0,229,255,.25);color:var(--cyan);}
.lp-ds{background:rgba(189,147,249,.08);border-color:rgba(189,147,249,.25);color:var(--purple);}
.lp-db{background:rgba(255,110,180,.08);border-color:rgba(255,110,180,.25);color:var(--pink);}
.lp-os{background:rgba(255,85,85,.08);border-color:rgba(255,85,85,.25);color:var(--red);}
.lp-cn{background:rgba(0,229,255,.08);border-color:rgba(0,229,255,.2);color:#7dcfff;}

.auth-card{background:var(--card);border:1px solid var(--border2);border-radius:16px;padding:32px;box-shadow:0 32px 80px rgba(0,0,0,.6);}
.auth-card h2{font-size:20px;font-weight:700;letter-spacing:-.02em;margin-bottom:5px;}
.auth-card .sub{color:var(--muted2);font-size:13px;margin-bottom:24px;}

.tabs{display:flex;background:rgba(255,255,255,.04);border-radius:8px;padding:3px;margin-bottom:24px;gap:3px;}
.tab-btn{flex:1;padding:8px;border:none;border-radius:6px;background:transparent;color:var(--muted2);font-family:var(--sans);font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;}
.tab-btn.active{background:var(--cyan);color:var(--bg);}

.form-group{margin-bottom:16px;}
.form-group label{display:block;font-family:var(--mono);font-size:11px;font-weight:600;letter-spacing:.06em;color:var(--muted2);margin-bottom:7px;text-transform:uppercase;}
.inp-wrap{position:relative;}
.inp-ico{position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:14px;opacity:.5;}
.form-group input,.form-group select{width:100%;padding:11px 12px 11px 38px;background:rgba(255,255,255,.05);border:1px solid var(--border2);border-radius:8px;color:var(--text);font-family:var(--sans);font-size:13.5px;outline:none;transition:border-color .2s,background .2s;-webkit-appearance:none;}
.form-group input:focus,.form-group select:focus{border-color:var(--cyan);background:rgba(0,229,255,.04);}
.form-group select option{background:var(--card);}

.row2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

.err-msg{background:rgba(255,85,85,.1);border:1px solid rgba(255,85,85,.3);border-radius:8px;padding:10px 14px;font-size:13px;color:var(--red);margin-bottom:14px;display:none;}
.ok-msg{background:rgba(57,255,144,.1);border:1px solid rgba(57,255,144,.3);border-radius:8px;padding:10px 14px;font-size:13px;color:var(--green);margin-bottom:14px;display:none;}

.btn-auth{width:100%;padding:13px;background:var(--cyan);border:none;border-radius:8px;color:var(--bg);font-family:var(--sans);font-size:14px;font-weight:700;cursor:pointer;letter-spacing:-.01em;transition:transform .15s,box-shadow .15s;box-shadow:0 4px 20px rgba(0,229,255,.25);}
.btn-auth:hover{transform:translateY(-1px);box-shadow:0 8px 28px rgba(0,229,255,.4);}

.divider{display:flex;align-items:center;gap:10px;margin:16px 0;color:var(--muted);font-size:12px;}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--border2);}

.api-key-section{background:rgba(189,147,249,.06);border:1px solid rgba(189,147,249,.2);border-radius:10px;padding:14px;margin-top:16px;}
.api-key-section p{font-size:12px;color:var(--muted2);margin-bottom:10px;line-height:1.5;}
.api-key-section a{color:var(--purple);text-decoration:none;}
.api-input{display:flex;gap:8px;}
.api-input input{flex:1;padding:9px 12px;background:rgba(255,255,255,.05);border:1px solid rgba(189,147,249,.25);border-radius:7px;color:var(--text);font-family:var(--mono);font-size:12px;outline:none;}
.api-input input:focus{border-color:var(--purple);}
.api-save-btn{padding:9px 14px;background:rgba(189,147,249,.15);border:1px solid rgba(189,147,249,.3);border-radius:7px;color:var(--purple);font-family:var(--sans);font-size:12px;font-weight:600;cursor:pointer;}

/* ══════════════════════════════════════════ APP */
#appShell{display:flex;min-height:100vh;}

.sidebar{width:232px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100;}

.sb-brand{padding:20px 18px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border);}
.sb-logo{width:34px;height:34px;background:var(--cyan);border-radius:6px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-weight:700;font-size:14px;color:var(--bg);flex-shrink:0;}
.sb-title{font-family:var(--mono);font-size:15px;font-weight:700;}
.sb-title span{color:var(--cyan);}

nav{padding:14px 10px;flex:1;overflow-y:auto;}
nav::-webkit-scrollbar{width:3px;}
nav::-webkit-scrollbar-thumb{background:var(--border2);}

.nav-sec{margin-bottom:20px;}
.nav-lbl{font-family:var(--mono);font-size:9.5px;font-weight:700;letter-spacing:.1em;color:var(--muted);padding:0 8px;margin-bottom:5px;text-transform:uppercase;}

.nav-item{display:flex;align-items:center;gap:9px;padding:9px 10px;border-radius:7px;cursor:pointer;font-size:13px;font-weight:500;color:var(--muted2);transition:all .15s;border:none;background:transparent;width:100%;text-align:left;font-family:var(--sans);}
.nav-item:hover{background:rgba(255,255,255,.05);color:var(--text);}
.nav-item.active{background:rgba(0,229,255,.08);color:var(--cyan);border:1px solid rgba(0,229,255,.15);}
.nav-ico{font-size:15px;width:20px;text-align:center;}
.nav-badge{margin-left:auto;background:var(--red);color:#fff;font-size:9px;font-weight:700;padding:1px 6px;border-radius:8px;}
.nav-badge.green{background:rgba(57,255,144,.2);color:var(--green);}

.sb-user{padding:14px 18px;border-top:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.sb-avatar{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--cyan),var(--purple));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:var(--bg);flex-shrink:0;}
.sb-uname{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sb-urole{font-family:var(--mono);font-size:10px;color:var(--muted2);}
.sb-logout{background:none;border:none;cursor:pointer;color:var(--muted);font-size:14px;padding:4px;margin-left:auto;transition:color .2s;}
.sb-logout:hover{color:var(--red);}

.main{margin-left:232px;flex:1;padding:24px 28px;min-height:100vh;}

.topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;}
.pg-title{font-size:20px;font-weight:800;letter-spacing:-.02em;}
.pg-title .pg-sub{font-size:12px;font-weight:400;color:var(--muted2);margin-top:1px;font-family:var(--mono);}

.topbar-right{display:flex;align-items:center;gap:10px;}
.search-bar{display:flex;align-items:center;gap:8px;background:var(--card);border:1px solid var(--border2);border-radius:8px;padding:8px 12px;width:190px;}
.search-bar input{background:none;border:none;outline:none;color:var(--text);font-family:var(--sans);font-size:13px;width:100%;}
.search-bar input::placeholder{color:var(--muted);}
.ico-btn{width:36px;height:36px;background:var(--card);border:1px solid var(--border2);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;cursor:pointer;transition:background .2s;position:relative;}
.ico-btn:hover{background:rgba(255,255,255,.08);}
.notif-dot{position:absolute;top:5px;right:5px;width:7px;height:7px;background:var(--red);border-radius:50%;border:2px solid var(--bg);}

/* ══════════════════════════════════════════ PANELS */
.panel{display:none;}
.panel.active{display:block;}

/* ── DASHBOARD */
.welcome-bar{background:linear-gradient(135deg,rgba(0,229,255,.1) 0%,rgba(57,255,144,.05) 100%);border:1px solid rgba(0,229,255,.2);border-radius:14px;padding:22px 26px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;position:relative;overflow:hidden;}
.welcome-bar::after{content:'</ engineer>';position:absolute;right:180px;top:50%;transform:translateY(-50%);font-family:var(--mono);font-size:64px;font-weight:700;color:rgba(0,229,255,.04);white-space:nowrap;}
.wb-text h2{font-size:18px;font-weight:800;letter-spacing:-.02em;margin-bottom:4px;}
.wb-text p{color:var(--muted2);font-size:13px;}
.wb-streak{background:rgba(255,123,53,.1);border:1px solid rgba(255,123,53,.25);border-radius:10px;padding:12px 16px;text-align:center;flex-shrink:0;}
.wb-streak .sf{font-size:22px;}
.wb-streak .sc{font-size:22px;font-weight:800;color:var(--orange);}
.wb-streak .sl{font-family:var(--mono);font-size:10px;color:var(--muted2);text-transform:uppercase;letter-spacing:.06em;}

.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;}
.stat-c{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:18px;transition:transform .2s,border-color .2s;}
.stat-c:hover{transform:translateY(-2px);border-color:var(--border2);}
.sc-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.sc-ico{width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;}
.sc-delta{font-family:var(--mono);font-size:10px;font-weight:600;padding:2px 7px;border-radius:5px;}
.delta-up{background:rgba(57,255,144,.1);color:var(--green);}
.delta-dn{background:rgba(255,85,85,.1);color:var(--red);}
.sc-val{font-size:26px;font-weight:800;letter-spacing:-.02em;margin-bottom:2px;}
.sc-lbl{font-size:12px;color:var(--muted2);}

.two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;}
.three-col{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px;}
.sec-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:18px;}

.sec-hd{font-size:13px;font-weight:700;letter-spacing:-.01em;display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.sec-act{font-family:var(--mono);font-size:11px;color:var(--cyan);cursor:pointer;background:none;border:none;font-family:var(--mono);}

.subj-row{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.subj-ico{font-size:15px;width:26px;text-align:center;}
.subj-info{flex:1;}
.subj-nm{font-size:12px;font-weight:600;margin-bottom:3px;display:flex;align-items:center;justify-content:space-between;}
.subj-nm span{font-family:var(--mono);font-size:11px;}
.subj-bar{height:5px;border-radius:3px;background:rgba(255,255,255,.06);}
.subj-fill{height:100%;border-radius:3px;transition:width 1s ease;}

.act-item{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);}
.act-item:last-child{border:none;}
.act-dot{width:7px;height:7px;border-radius:50%;margin-top:5px;flex-shrink:0;}
.act-label{font-size:13px;font-weight:500;margin-bottom:2px;}
.act-meta{font-family:var(--mono);font-size:10px;color:var(--muted);}
.act-score{font-family:var(--mono);font-size:12px;font-weight:700;}

/* ── AI TUTOR */
.tutor-layout{display:grid;grid-template-columns:1fr 280px;gap:16px;height:calc(100vh - 130px);}
.chat-main{background:var(--card);border:1px solid var(--border);border-radius:14px;display:flex;flex-direction:column;overflow:hidden;}
.chat-hd{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;}
.ai-av{width:36px;height:36px;background:linear-gradient(135deg,var(--cyan),var(--purple));border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-weight:700;font-size:13px;color:var(--bg);}
.ai-stat{font-family:var(--mono);font-size:11px;color:var(--green);display:flex;align-items:center;gap:5px;}
.ai-stat::before{content:'';width:6px;height:6px;background:var(--green);border-radius:50%;}
.model-badge{font-family:var(--mono);font-size:10px;padding:3px 9px;border-radius:5px;background:rgba(189,147,249,.1);border:1px solid rgba(189,147,249,.25);color:var(--purple);margin-left:auto;}

.chat-msgs{flex:1;overflow-y:auto;padding:18px;display:flex;flex-direction:column;gap:14px;}
.chat-msgs::-webkit-scrollbar{width:3px;}
.chat-msgs::-webkit-scrollbar-thumb{background:var(--border2);}

.msg{max-width:82%;animation:msgSlide .3s ease;}
@keyframes msgSlide{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.msg.user{align-self:flex-end;}
.msg-lbl{font-family:var(--mono);font-size:9px;font-weight:700;letter-spacing:.08em;color:var(--muted);margin-bottom:5px;text-transform:uppercase;}
.msg.user .msg-lbl{text-align:right;}
.msg-bub{padding:11px 15px;border-radius:10px;font-size:13.5px;line-height:1.65;}
.msg.ai .msg-bub{background:rgba(255,255,255,.05);border:1px solid var(--border2);border-radius:3px 10px 10px 10px;}
.msg.user .msg-bub{background:var(--cyan);color:var(--bg);font-weight:500;border-radius:10px 10px 3px 10px;}

/* Code blocks in chat */
.msg-bub pre{background:var(--bg);border:1px solid rgba(0,229,255,.15);border-radius:8px;padding:12px 14px;margin:10px 0;overflow-x:auto;}
.msg-bub pre code{font-family:var(--mono);font-size:12px;line-height:1.6;color:var(--green);}
.msg-bub .code-lang{font-family:var(--mono);font-size:10px;color:var(--cyan);background:rgba(0,229,255,.08);padding:2px 8px;border-radius:4px;margin-bottom:6px;display:inline-block;}
.msg-bub strong{color:var(--cyan);}
.msg-bub .key{color:var(--purple);}
.msg-bub .val{color:var(--green);}

.typing-dots span{display:inline-block;width:5px;height:5px;background:var(--cyan);border-radius:50%;margin:0 2px;animation:typeDot 1.2s infinite;}
.typing-dots span:nth-child(2){animation-delay:.2s;}
.typing-dots span:nth-child(3){animation-delay:.4s;}
@keyframes typeDot{0%,60%,100%{transform:translateY(0);}30%{transform:translateY(-6px);}}

.chat-inp-area{padding:14px 18px;border-top:1px solid var(--border);display:flex;gap:9px;align-items:flex-end;}
.chat-inp{flex:1;background:rgba(255,255,255,.05);border:1px solid var(--border2);border-radius:10px;padding:11px 14px;color:var(--text);font-family:var(--sans);font-size:13.5px;resize:none;outline:none;max-height:120px;line-height:1.5;transition:border-color .2s;}
.chat-inp:focus{border-color:var(--cyan);}
.send-btn{width:42px;height:42px;background:var(--cyan);border:none;border-radius:9px;cursor:pointer;font-size:17px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .15s,box-shadow .15s;color:var(--bg);}
.send-btn:hover{transform:scale(1.05);box-shadow:0 4px 16px rgba(0,229,255,.4);}
.send-btn:disabled{opacity:.3;cursor:not-allowed;transform:none;}

.tutor-sb{display:flex;flex-direction:column;gap:14px;}
.topic-grid{display:flex;flex-direction:column;gap:5px;}
.topic-chip{padding:9px 12px;border-radius:7px;background:rgba(255,255,255,.03);border:1px solid var(--border);color:var(--text);font-family:var(--sans);font-size:12px;font-weight:500;cursor:pointer;text-align:left;transition:all .15s;}
.topic-chip:hover{background:rgba(0,229,255,.06);border-color:rgba(0,229,255,.25);color:var(--cyan);}
.topic-chip .tc-lang{font-family:var(--mono);font-size:10px;color:var(--muted2);margin-right:5px;}

/* ── QUIZ */
.quiz-pick{max-width:640px;margin:0 auto;padding:20px 0;}
.quiz-pick h2{font-size:26px;font-weight:800;letter-spacing:-.02em;margin-bottom:8px;}
.quiz-pick p{color:var(--muted2);font-size:13px;margin-bottom:28px;}
.qsubj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:24px;}
.qsubj-card{background:var(--card);border:2px solid var(--border);border-radius:12px;padding:16px;cursor:pointer;transition:all .2s;text-align:center;}
.qsubj-card:hover,.qsubj-card.sel{border-color:var(--cyan);}
.qsubj-card.sel{background:rgba(0,229,255,.06);}
.qsubj-card .qs-ico{font-size:26px;margin-bottom:7px;}
.qsubj-card .qs-nm{font-size:13px;font-weight:700;margin-bottom:2px;}
.qsubj-card .qs-cnt{font-family:var(--mono);font-size:10px;color:var(--muted2);}
.diff-row{display:flex;gap:8px;justify-content:center;margin-bottom:28px;}
.diff-btn{padding:7px 20px;border-radius:7px;border:1.5px solid;font-family:var(--mono);font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;background:transparent;}
.diff-btn.sel-e{border-color:var(--green);background:rgba(57,255,144,.1);color:var(--green);}
.diff-btn.sel-m{border-color:var(--yellow);background:rgba(241,250,140,.1);color:var(--yellow);}
.diff-btn.sel-h{border-color:var(--red);background:rgba(255,85,85,.1);color:var(--red);}
.diff-btn:not([class*="sel-"]){border-color:var(--border2);color:var(--muted2);}
.btn-startq{padding:13px 36px;background:var(--cyan);border:none;border-radius:9px;color:var(--bg);font-family:var(--sans);font-size:14px;font-weight:700;cursor:pointer;box-shadow:0 4px 20px rgba(0,229,255,.25);transition:transform .15s;}
.btn-startq:hover{transform:translateY(-1px);}

.quiz-active{max-width:680px;margin:0 auto;}
.q-hdr{display:flex;align-items:center;gap:14px;margin-bottom:22px;}
.q-prog-bar{flex:1;height:5px;background:rgba(255,255,255,.07);border-radius:3px;overflow:hidden;}
.q-prog-fill{height:100%;background:var(--cyan);border-radius:3px;transition:width .4s ease;}
.q-timer-badge{font-family:var(--mono);font-size:13px;font-weight:700;padding:5px 13px;border-radius:7px;background:rgba(255,85,85,.1);border:1px solid rgba(255,85,85,.25);color:var(--red);}
.q-box{background:var(--card);border:1px solid var(--border2);border-radius:16px;padding:28px;}
.q-pills{display:flex;gap:8px;margin-bottom:16px;}
.q-q{font-size:17px;font-weight:700;line-height:1.55;margin-bottom:24px;letter-spacing:-.01em;}
.q-q code{font-family:var(--mono);background:rgba(0,229,255,.08);padding:1px 6px;border-radius:4px;font-size:14px;color:var(--cyan);}
.q-opts{display:flex;flex-direction:column;gap:9px;}
.q-opt{padding:13px 16px;border-radius:10px;border:1.5px solid var(--border2);background:rgba(255,255,255,.02);cursor:pointer;font-size:13.5px;font-weight:500;transition:all .15s;display:flex;align-items:center;gap:11px;}
.q-opt:hover{border-color:var(--cyan);background:rgba(0,229,255,.04);}
.q-opt.chosen{border-color:var(--purple);background:rgba(189,147,249,.08);}
.q-opt.correct{border-color:var(--green)!important;background:rgba(57,255,144,.08)!important;}
.q-opt.wrong{border-color:var(--red)!important;background:rgba(255,85,85,.07)!important;}
.q-opt-ltr{width:26px;height:26px;border-radius:6px;background:rgba(255,255,255,.06);display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:11px;font-weight:700;flex-shrink:0;}
.q-opt code{font-family:var(--mono);background:rgba(255,255,255,.06);padding:1px 5px;border-radius:3px;font-size:12px;}
.q-foot{display:flex;align-items:center;justify-content:space-between;margin-top:20px;}
.q-fb{font-size:13px;}
.btn-next{padding:10px 24px;background:var(--cyan);border:none;border-radius:8px;color:var(--bg);font-family:var(--sans);font-size:13px;font-weight:700;cursor:pointer;transition:opacity .2s;}
.btn-next:disabled{opacity:.3;cursor:not-allowed;}

.quiz-res{max-width:520px;margin:0 auto;text-align:center;padding:20px 0;}
.res-ring{width:130px;height:130px;margin:0 auto 22px;border-radius:50%;background:conic-gradient(var(--cyan) var(--sdeg),rgba(255,255,255,.06) 0);display:flex;align-items:center;justify-content:center;position:relative;}
.res-ring::before{content:'';position:absolute;width:100px;height:100px;background:var(--bg);border-radius:50%;}
.res-pct{position:relative;z-index:1;font-family:var(--mono);font-size:28px;font-weight:700;color:var(--cyan);}
.res-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:22px 0;}
.res-stat{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:14px;}
.res-stat .rv{font-family:var(--mono);font-size:20px;font-weight:700;}
.res-stat .rl{font-size:11px;color:var(--muted2);margin-top:2px;}

/* ── ROADMAP */
.roadmap-wrap{max-width:900px;}
.lang-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:22px;}
.lang-tab{padding:7px 16px;border-radius:7px;border:1px solid var(--border2);color:var(--muted2);font-family:var(--mono);font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;background:transparent;}
.lang-tab.active{background:var(--cyan);color:var(--bg);border-color:var(--cyan);}

.roadmap-track{position:relative;padding-left:32px;}
.roadmap-track::before{content:'';position:absolute;left:11px;top:0;bottom:0;width:2px;background:linear-gradient(var(--cyan),var(--purple));}
.rm-phase{margin-bottom:24px;}
.rm-dot{position:absolute;left:0;width:24px;height:24px;border-radius:50%;border:2px solid var(--cyan);background:var(--bg);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;font-family:var(--mono);color:var(--cyan);}
.rm-dot.done{background:var(--cyan);color:var(--bg);}
.rm-header{display:flex;align-items:center;gap:10px;margin-bottom:10px;padding-left:14px;position:relative;}
.rm-phase-title{font-size:14px;font-weight:700;}
.rm-topics{padding-left:14px;display:flex;flex-wrap:wrap;gap:7px;}
.rm-topic{padding:5px 12px;border-radius:6px;font-size:12px;font-weight:600;font-family:var(--mono);cursor:pointer;transition:all .2s;}
.rm-topic.done-t{background:rgba(57,255,144,.1);border:1px solid rgba(57,255,144,.25);color:var(--green);text-decoration:line-through;opacity:.6;}
.rm-topic.active-t{background:rgba(0,229,255,.1);border:1px solid rgba(0,229,255,.3);color:var(--cyan);}
.rm-topic.locked-t{background:rgba(255,255,255,.03);border:1px solid var(--border);color:var(--muted);}

/* ── PROFILE */
.prof-hero{background:linear-gradient(135deg,var(--card) 0%,rgba(0,229,255,.08) 100%);border:1px solid var(--border2);border-radius:14px;padding:24px 28px;display:flex;align-items:center;gap:22px;margin-bottom:20px;}
.prof-av{width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,var(--cyan),var(--purple));display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:800;color:var(--bg);flex-shrink:0;}
.prof-nm{font-size:20px;font-weight:800;letter-spacing:-.02em;margin-bottom:3px;}
.prof-sub{font-family:var(--mono);font-size:11px;color:var(--muted2);margin-bottom:10px;}
.prof-badges{display:flex;gap:7px;flex-wrap:wrap;}
.pbadge{padding:3px 9px;border-radius:5px;font-size:11px;font-weight:700;font-family:var(--mono);}
.xp-wrap{margin-top:10px;max-width:360px;}
.xp-labels{display:flex;justify-content:space-between;font-family:var(--mono);font-size:10px;color:var(--muted2);margin-bottom:4px;}
.xp-bar{height:7px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden;}
.xp-fill{height:100%;background:linear-gradient(90deg,var(--cyan),var(--purple));border-radius:3px;transition:width 1s;}

/* ── SETTINGS */
.settings-wrap{max-width:560px;}
.set-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:18px;margin-bottom:14px;}
.set-hd{font-size:13px;font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:7px;}
.set-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);}
.set-row:last-child{border:none;}
.set-info .set-nm{font-size:13px;font-weight:600;margin-bottom:2px;}
.set-info .set-ds{font-size:12px;color:var(--muted2);}
.toggle{width:42px;height:22px;border-radius:11px;position:relative;cursor:pointer;transition:background .2s;flex-shrink:0;}
.toggle.on{background:var(--cyan);}
.toggle.off{background:rgba(255,255,255,.1);}
.toggle::after{content:'';position:absolute;top:3px;width:16px;height:16px;background:#fff;border-radius:50%;transition:left .2s;}
.toggle.on::after{left:23px;}
.toggle.off::after{left:3px;}

.api-key-manage{background:rgba(189,147,249,.05);border:1px solid rgba(189,147,249,.2);border-radius:10px;padding:14px;}
.api-key-manage p{font-size:12px;color:var(--muted2);margin-bottom:10px;line-height:1.5;}
.api-key-display{font-family:var(--mono);font-size:12px;color:var(--purple);background:rgba(189,147,249,.08);padding:8px 12px;border-radius:6px;margin-bottom:10px;word-break:break-all;}

@keyframes fadeUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
.anim{animation:fadeUp .35s ease both;}

/* ── TOAST */
.toast{position:fixed;bottom:24px;right:24px;padding:12px 18px;border-radius:9px;font-size:13px;font-weight:600;z-index:9999;animation:toastIn .3s ease;display:none;}
.toast.show{display:block;}
.toast.success{background:rgba(57,255,144,.15);border:1px solid rgba(57,255,144,.3);color:var(--green);}
.toast.error{background:rgba(255,85,85,.15);border:1px solid rgba(255,85,85,.3);color:var(--red);}
@keyframes toastIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}

@media(max-width:900px){
  .auth-wrap{grid-template-columns:1fr;max-width:420px;}
  .auth-hero{display:none;}
  .sidebar{transform:translateX(-100%);}
  .main{margin-left:0;}
  .stats-grid{grid-template-columns:1fr 1fr;}
  .two-col,.three-col{grid-template-columns:1fr;}
  .tutor-layout{grid-template-columns:1fr;}
}
</style>
</head>
