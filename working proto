function persistChatActivity(question) {
  const users = JSON.parse(localStorage.getItem('enginex_users') || '{}');
  if (!users[currentUser.email]) return;
  const act = users[currentUser.email].data.activity;
  act.unshift({ subj: question.slice(0, 45) + (question.length > 45 ? '…' : ''), score: 0, date: 'Just now', type: 'Chat' });
  if (act.length > 20) act.pop();
  users[currentUser.email].data.xp = (users[currentUser.email].data.xp || 0) + 15;
  localStorage.setItem('enginex_users', JSON.stringify(users));
}

function formatMsg(text) {
  text = text.replace(/```(\w+)?\n([\s\S]*?)```/g, (_, lang, code) =>
    `<div class="code-lang">${lang || 'code'}</div><pre><code>${escH(code.trim())}</code></pre>`);
  text = text.replace(/`([^`]+)`/g, '<code style="font-family:var(--mono);background:rgba(0,229,255,.08);padding:1px 5px;border-radius:3px;color:var(--cyan)">$1</code>');
  text = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  text = text.replace(/\n/g, '<br>');
  return text;
}
function escH(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function addChatMsg(role, html) {
  const el = document.createElement('div');
  el.className = `msg ${role}`;
  el.innerHTML = `<div class="msg-lbl">${role === 'ai' ? 'AI Tutor' : 'You'}</div><div class="msg-bub">${html}</div>`;
  document.getElementById('chatMsgs').appendChild(el);
  scrollChat();
}
