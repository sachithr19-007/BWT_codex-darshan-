function getDemoResponse(q) {
  const ql = q.toLowerCase();
  if (ql.includes('decorator'))
    return `**Python Decorators** 🐍\n\nDecorators wrap functions to add behaviour without modifying the original.\n\n\`\`\`python\nimport time\n\ndef timer(func):\n    def wrapper(*args, **kwargs):\n        t = time.perf_counter()\n        result = func(*args, **kwargs)\n        print(f"{func.__name__} ran in {time.perf_counter()-t:.4f}s")\n        return result\n    return wrapper\n\n@timer\ndef slow():\n    time.sleep(0.3)\n\nslow()  # slow ran in 0.3001s\`\`\`\n\n**Key points:**\n• A decorator is a higher-order function\n• \`@name\` is sugar for \`func = name(func)\`\n• Common uses: logging, auth, caching (functools.lru_cache)\n\n> 💡 Add your Anthropic API key for live, context-aware answers!`;
  if (ql.includes('event loop') || ql.includes('javascript'))
    return `**JavaScript Event Loop** ⚡\n\nJS is single-threaded but handles async via the event loop.\n\n\`\`\`javascript\nconsole.log('1 - sync');\n\nsetTimeout(() => console.log('3 - macro task'), 0);\n\nPromise.resolve().then(() => console.log('2 - micro task'));\n\n// Output: 1 → 2 → 3\n// Why? Microtasks (Promises) run BEFORE macrotasks (setTimeout)\`\`\`\n\n**Order:** Call Stack → Microtask Queue → Macrotask Queue\n\n> 💡 Add your API key for real Claude responses!`;
  if (ql.includes('big o') || ql.includes('complexity') || ql.includes('dsa'))
    return `**Big O Notation** 🌲\n\n| Notation | Name | Example |\n|---|---|---|\n| O(1) | Constant | Array index |\n| O(log n) | Log | Binary Search |\n| O(n) | Linear | Linear Search |\n| O(n log n) | Linearithmic | Merge Sort |\n| O(n²) | Quadratic | Bubble Sort |\n\n\`\`\`python\n# O(n²) — avoid for large n\nfor i in range(n):\n    for j in range(n):\n        process(i, j)\n\n# O(n log n) — merge sort\ndef merge_sort(arr):\n    if len(arr) <= 1: return arr\n    mid = len(arr) // 2\n    return merge(merge_sort(arr[:mid]), merge_sort(arr[mid:]))\`\`\`\n\n> 💡 Add your API key for live answers!`;
  return `Great question! 👾 This is a core topic in engineering interviews.\n\nHere's a quick outline:\n• **Understand fundamentals** before memorising solutions\n• **Draw diagrams** for system/OS/network concepts\n• **Write code** for algorithms — don't just read\n\n> 💡 **Add your Anthropic API key** in Settings for real Claude AI answers with full code examples tailored to your exact question!`;
}

// ══════════════════════════════════════════ QUIZ — AI POWERED
function pickSubj(el, id) {
  document.querySelectorAll('.qsubj-card').forEach(c => c.classList.remove('sel'));
  el.classList.add('sel');
  selectedSubj = id;
}
function pickDiff(btn, d) {
  document.querySelectorAll('.diff-btn').forEach(b => {
    b.className = 'diff-btn';
    b.textContent = b.textContent.replace(' ✓', '');
  });
  btn.className = `diff-btn ${d==='Easy'?'sel-e':d==='Medium'?'sel-m':'sel-h'}`;
  btn.textContent = d + ' ✓';
  selectedDiff = d;
}

async function startQuiz() {
  quizState = { subj: selectedSubj, diff: selectedDiff, q: 0, score: 0, timer: null, timerVal: 35, answered: false };

  // Show loading state
  document.getElementById('quizPick').classList.add('hidden');
  document.getElementById('quizActive').classList.remove('hidden');
  document.getElementById('quizRes').classList.add('hidden');
  document.getElementById('qText').innerHTML = '';
  document.getElementById('qOpts').innerHTML = '';
  document.getElementById('qPills').innerHTML = '';
  document.getElementById('qNum').textContent = '—';
  document.getElementById('qPF').style.width = '0%';
  document.getElementById('qTimer').textContent = '⏱ …';
  document.getElementById('btnNext').disabled = true;
  document.getElementById('qFb').textContent = '';
  document.getElementById('qText').innerHTML = `
    <div style="text-align:center;padding:30px 0;">
      <div class="typing-dots" style="justify-content:center;display:flex;margin-bottom:16px"><span></span><span></span><span></span></div>
      <div style="color:var(--muted2);font-size:13px;">${apiKey ? '🤖 Generating AI questions for <strong>' + (SUBJECTS.find(s=>s.id===selectedSubj)?.nm||selectedSubj) + '</strong> — ' + selectedDiff + ' difficulty…' : '📚 Loading questions…'}</div>
    </div>`;

  try {
    if (apiKey) {
      generatedQ = await generateQuestions(selectedSubj, selectedDiff);
    } else {
      // Use fallback bank with shuffle
      const bank = FALLBACK_Q[selectedSubj] || FALLBACK_Q.dsa;
      // Pad to 10 by repeating if needed
      const extended = [...bank];
      while (extended.length < 10) extended.push(...bank);
      generatedQ = extended.sort(() => Math.random() - .5).slice(0, 10);
    }
    renderQ();
  } catch (err) {
    // JSON parse failed or API error — fall back
    console.warn('AI quiz gen failed:', err.message);
    const bank = FALLBACK_Q[selectedSubj] || FALLBACK_Q.dsa;
    const extended = [...bank];
    while (extended.length < 10) extended.push(...bank);
    generatedQ = extended.sort(() => Math.random() - .5).slice(0, 10);
    toast('Using offline questions (API error).', 'error');
    renderQ();
  }
}

function renderQ() {
  const q = generatedQ[quizState.q];
  quizState.answered = false;
  document.getElementById('qNum').textContent = quizState.q + 1;
  document.getElementById('qPF').style.width  = ((quizState.q + 1) / 10 * 100) + '%';
  document.getElementById('btnNext').disabled = true;
  document.getElementById('qFb').textContent  = '';

  const subj = SUBJECTS.find(s => s.id === quizState.subj) || SUBJECTS[4];
  document.getElementById('qPills').innerHTML = `
    <span class="lang-pill" style="background:rgba(0,229,255,.08);border-color:rgba(0,229,255,.25);color:var(--cyan)">${subj.ico} ${subj.nm}</span>
    <span class="lang-pill" style="background:rgba(189,147,249,.08);border-color:rgba(189,147,249,.25);color:var(--purple)">${selectedDiff}</span>
    ${apiKey ? '<span class="lang-pill" style="background:rgba(57,255,144,.08);border-color:rgba(57,255,144,.2);color:var(--green);font-size:10px">✦ AI Generated</span>' : ''}`;

  // Render question (handle code backticks)
  document.getElementById('qText').innerHTML = (q.q || '').replace(/`([^`]+)`/g,
    '<code style="font-family:var(--mono);background:rgba(0,229,255,.08);padding:2px 6px;border-radius:4px;font-size:14px;color:var(--cyan)">$1</code>');

  const ltrs = ['A','B','C','D'];
  document.getElementById('qOpts').innerHTML = (q.opts || []).map((o, i) =>
    `<div class="q-opt" onclick="pickAns(this,${i})">
      <div class="q-opt-ltr">${ltrs[i]}</div>
      ${String(o).replace(/`([^`]+)`/g,'<code style="font-family:var(--mono);background:rgba(255,255,255,.07);padding:1px 5px;border-radius:3px">$1</code>')}
    </div>`).join('');

  clearInterval(quizState.timer);
  quizState.timerVal = selectedDiff === 'Easy' ? 45 : selectedDiff === 'Medium' ? 35 : 25;
  document.getElementById('qTimer').textContent = `⏱ ${quizState.timerVal}s`;
  quizState.timer = setInterval(() => {
    quizState.timerVal--;
    document.getElementById('qTimer').textContent = `⏱ ${quizState.timerVal}s`;
    if (quizState.timerVal <= 0) { clearInterval(quizState.timer); if (!quizState.answered) timeUp(); }
  }, 1000);
}

let wrongTopicsList = [];
function pickAns(el, idx) {
  if (quizState.answered) return;
  quizState.answered = true;
  clearInterval(quizState.timer);
  const correct = generatedQ[quizState.q].c;
  const exp     = generatedQ[quizState.q].exp || '';
  document.querySelectorAll('.q-opt').forEach((o, i) => {
    if (i === correct) o.classList.add('correct');
    else if (i === idx && i !== correct) o.classList.add('wrong');
  });
  if (idx === correct) {
    quizState.score++;
    document.getElementById('qFb').innerHTML = `<span style="color:var(--green)">✓ Correct! ${exp}</span>`;
  } else {
    wrongTopicsList.push(generatedQ[quizState.q].q.slice(0, 40));
    document.getElementById('qFb').innerHTML = `<span style="color:var(--red)">✗ Wrong. ${exp}</span>`;
  }
  document.getElementById('btnNext').disabled = false;
}

function timeUp() {
  quizState.answered = true;
  const correct = generatedQ[quizState.q].c;
  document.querySelectorAll('.q-opt')[correct]?.classList.add('correct');
  wrongTopicsList.push(generatedQ[quizState.q].q.slice(0, 40));
  document.getElementById('qFb').innerHTML = `<span style="color:var(--yellow)">⏱ Time's up! Correct: ${generatedQ[quizState.q].opts[correct]}</span>`;
  document.getElementById('btnNext').disabled = false;
}

function nextQ() {
  quizState.q++;
  if (quizState.q >= 10) showQuizResults();
  else renderQ();
}

async function showQuizResults() {
  clearInterval(quizState.timer);
  document.getElementById('quizActive').classList.add('hidden');
  document.getElementById('quizRes').classList.remove('hidden');

  const pct = Math.round(quizState.score / 10 * 100);
  const xp  = quizState.score * 20;
  document.getElementById('resPct').textContent = pct + '%';
  document.getElementById('resRing').style.setProperty('--sdeg', (pct * 3.6) + 'deg');
  document.getElementById('resC').textContent   = quizState.score;
  document.getElementById('resW').textContent   = 10 - quizState.score;
  document.getElementById('resXP').textContent  = '+' + xp;

  const msgs = [
    [80, 'Outstanding! 🏆', 'Top-tier performance. Push to the next difficulty!'],
    [60, 'Good Work! 👍',   'Solid effort. Review the incorrect answers.'],
    [0,  'Keep Going! 💪',  'Every attempt builds knowledge. Try again!'],
  ];
  for (const [min, title, msg] of msgs) {
    if (pct >= min) {
      document.getElementById('resTitle').textContent = title;
      document.getElementById('resMsg').textContent   = msg;
      break;
    }
  }

  // AI insight block
  document.getElementById('resMsg').insertAdjacentHTML('afterend',
    `<div id="aiInsight" style="margin-top:14px;padding:14px;background:rgba(189,147,249,.07);border:1px solid rgba(189,147,249,.2);border-radius:10px;font-size:13px;color:var(--muted2);text-align:left">
      <div class="typing-dots" style="display:flex"><span></span><span></span><span></span></div>
    </div>`);

  // Persist real data
  const users = JSON.parse(localStorage.getItem('enginex_users') || '{}');
  if (users[currentUser.email]) {
    const ud = users[currentUser.email].data;
    ud.tests  = (ud.tests  || 0) + 1;
    ud.xp     = (ud.xp     || 0) + xp;
    // Rolling average score
    const prevTotal = (ud.avgScore || 0) * (ud.tests - 1);
    ud.avgScore = Math.round((prevTotal + pct) / ud.tests);
    // Subject score history
    if (!ud.subjectScores) ud.subjectScores = {};
    if (!ud.subjectScores[quizState.subj]) ud.subjectScores[quizState.subj] = [];
    ud.subjectScores[quizState.subj].push(pct);
    if (ud.subjectScores[quizState.subj].length > 20) ud.subjectScores[quizState.subj].shift();
    // Activity log
    const subj = SUBJECTS.find(s => s.id === quizState.subj);
    ud.activity.unshift({
      subj:  `${subj.nm} Mock Test (${selectedDiff})`,
      score: pct,
      date:  'Just now',
      type:  'Test',
    });
    if (ud.activity.length > 20) ud.activity.pop();
    // Weekly minutes (approximate current day index)
    const dayIdx = new Date().getDay(); // 0=Sun,1=Mon…
    const mapped = [6,0,1,2,3,4,5][dayIdx]; // map to Mon=0
    ud.weeklyMins = ud.weeklyMins || [0,0,0,0,0,0,0];
    ud.weeklyMins[mapped] = (ud.weeklyMins[mapped] || 0) + 10;
    localStorage.setItem('enginex_users', JSON.stringify(users));
    currentUser = users[currentUser.email];
    appData = { tests:ud.tests, xp:ud.xp, avgScore:ud.avgScore, streak:ud.streak||1 };
    // refresh sidebar XP
    document.getElementById('sbRole').textContent = `Level ${Math.floor(ud.xp/500)+1} · ${currentUser.branch.split(' ')[0]}`;
  }

  // Fetch AI insight
  const subjNm = SUBJECTS.find(s => s.id === quizState.subj)?.nm || quizState.subj;
  const insight = await generateQuizInsight(subjNm, quizState.score, wrongTopicsList);
  const el = document.getElementById('aiInsight');
  if (el) {
    el.innerHTML = insight
      ? `<strong style="color:var(--purple)">✦ AI Insight</strong><br>${insight.replace(/\n/g,'<br>')}`
      : `<span style="color:var(--muted)">Add your API key for personalised AI feedback after each quiz.</span>`;
  }
  wrongTopicsList = [];
}

function resetQuiz() {
  document.getElementById('quizRes').classList.add('hidden');
  document.getElementById('quizPick').classList.remove('hidden');
  const insight = document.getElementById('aiInsight');
  if (insight) insight.remove();
  renderQuizPicker();
  refreshDashboard();
}

// ══════════════════════════════════════════ ROADMAP
let activeRoadmapLang = 'python';

function initRoadmap() {
  const ids = Object.keys(ROADMAPS);
  document.getElementById('langTabs').innerHTML =
    ids.map(id => `<button class="lang-tab ${id === activeRoadmapLang ? 'active':''}" onclick="switchRoadmap('${id}',this)">${ROADMAPS[id].label}</button>`).join('') +
    SUBJECTS.filter(s => !ids.includes(s.id)).map(s => `<button class="lang-tab" style="opacity:.4">${s.ico} ${s.nm}</button>`).join('');
  renderRoadmap();
}
function switchRoadmap(id, btn) {
  activeRoadmapLang = id;
  document.querySelectorAll('.lang-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderRoadmap();
}
function renderRoadmap() {
  const rm = ROADMAPS[activeRoadmapLang];
  if (!rm) { document.getElementById('roadmapContent').innerHTML = '<div style="color:var(--muted2);text-align:center;padding:40px">Roadmap coming soon! 🚧</div>'; return; }
  let html = '<div class="roadmap-track">';
  rm.phases.forEach((p, i) => {
    html += `<div class="rm-phase" style="position:relative">
      <div class="rm-dot ${p.done?'done':''}" style="${p.done?`background:${rm.color};border-color:${rm.color}`:p.active?`border-color:${rm.color};color:${rm.color}`:''}"> ${i+1}</div>
      <div class="rm-header">
        <div class="rm-phase-title">${p.n}</div>
        ${p.done ? `<span class="lang-pill" style="background:rgba(57,255,144,.08);border-color:rgba(57,255,144,.2);color:var(--green);font-size:10px">✓ Done</span>` :
          p.active ? `<span class="lang-pill" style="background:rgba(0,229,255,.08);border-color:rgba(0,229,255,.2);color:var(--cyan);font-size:10px">In Progress</span>` : ''}
      </div>
      <div class="rm-topics">
        ${p.topics.map(t => `<span class="rm-topic ${p.done?'done-t':p.active?'active-t':'locked-t'}">${t}</span>`).join('')}
      </div>
    </div>`;
  });
  html += '</div>';
  document.getElementById('roadmapContent').innerHTML = html;
}

// ══════════════════════════════════════════ PROGRESS  (real data)
function initProgress() {
  const d = currentUser.data;

  // Weekly minutes bar chart (real data)
  const wm = (d.weeklyMins || [0,0,0,0,0,0,0]);
  const maxMin = Math.max(...wm, 1);
  const todayIdx = [6,0,1,2,3,4,5][new Date().getDay()]; // Mon=0
  document.getElementById('weekChart').innerHTML = wm.map((m, i) =>
    `<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:3px">
      <div style="font-family:var(--mono);font-size:9px;color:var(--muted2)">${m}m</div>
      <div style="width:100%;height:${Math.max((m/maxMin)*100,4)}%;background:${i===todayIdx?'var(--cyan)':'rgba(0,229,255,.15)'};border-radius:3px;transition:height .5s"></div>
    </div>`).join('');

  // Score history from real activity
  const testActs = (d.activity || []).filter(a => a.type === 'Test').slice(0, 6);
  if (testActs.length === 0) {
    document.getElementById('scoreHist').innerHTML = `<div style="color:var(--muted2);font-size:13px;text-align:center;padding:20px">No tests completed yet. Take a Mock Test! ⚡</div>`;
  } else {
    document.getElementById('scoreHist').innerHTML = testActs.map(h => {
      const c = h.score >= 80 ? 'var(--green)' : h.score >= 60 ? 'var(--yellow)' : 'var(--red)';
      return `<div style="display:flex;align-items:center;justify-content:space-between;padding:9px;background:rgba(255,255,255,.02);border-radius:8px;margin-bottom:7px">
        <div><div style="font-size:13px;font-weight:600">${h.subj}</div><div style="font-family:var(--mono);font-size:10px;color:var(--muted)">${h.date}</div></div>
        <div style="font-family:var(--mono);font-size:15px;font-weight:700;color:${c}">${h.score}%</div>
      </div>`;
    }).join('');
  }

  // Subject progress from real scores
  const ss = d.subjectScores || {};
  document.getElementById('detailProg').innerHTML = SUBJECTS.map(s => {
    const arr = ss[s.id] || [];
    const p   = arr.length ? avg(arr) : 0;
    const cnt = arr.length ? `(${arr.length} test${arr.length>1?'s':''})` : 'No tests yet';
    return `<div style="margin-bottom:14px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:5px">
        <div style="display:flex;align-items:center;gap:8px"><span>${s.ico}</span><span style="font-size:13px;font-weight:600">${s.nm}</span><span style="font-family:var(--mono);font-size:10px;color:var(--muted2)">${cnt}</span></div>
        <span style="font-family:var(--mono);font-size:13px;font-weight:700;color:${arr.length?s.color:'var(--muted)'}">${arr.length?p+'%':'—'}</span>
      </div>
      <div style="height:7px;background:rgba(255,255,255,.06);border-radius:4px;overflow:hidden">
        <div style="width:${p}%;height:100%;background:${s.color};border-radius:4px;transition:width 1s ease"></div>
      </div>
    </div>`;
  }).join('');
}

