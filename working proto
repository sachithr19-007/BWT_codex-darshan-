function handleChatKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendChatMsg();}}

async function sendChatMsg(){
  const inp=document.getElementById('chatInput');
  const txt=inp.value.trim();
  if(!txt)return;
  inp.value='';inp.style.height='auto';
  addChatBubble('user',txt);
  document.getElementById('sendBtn').disabled=true;
  const cnt=parseInt(document.getElementById('chatMsgCount').textContent)+1;
  document.getElementById('chatMsgCount').textContent=cnt;
  
  const tid='typing_'+Date.now();
  document.getElementById('chatMsgs').insertAdjacentHTML('beforeend',
    `<div class="chat-msg ai" id="${tid}"><div class="msg-label">AI Tutor</div><div class="msg-bubble"><div class="typing-anim"><span></span><span></span><span></span></div></div></div>`);
  scrollChat();
  
  let reply;
  if(apiKey){
    try{
      chatHistory.push({role:'user',content:txt});
      const res=await fetch('https://api.groq.com/openai/v1/chat/completions',{
        method:'POST',
        headers:{'Content-Type':'application/json','Authorization':`Bearer ${apiKey}`},
        body:JSON.stringify({
          model:'llama-3.3-70b-versatile',max_tokens:1200,
          messages:[{
            role:'system',
            content:`You are EngineX AI — an expert CS and Engineering tutor for students.
Topics: Python, Java, JavaScript, C++, DSA, DBMS, Operating Systems, Computer Networks, System Design, Discrete Math.
Style: Use **bold** for key terms. Use triple-backtick code blocks with language name. Be concise, practical, exam-aware.
Always give a working code example when explaining algorithms or syntax. Address students by name if mentioned.
Format explanations clearly with bullets where needed.`
          },...chatHistory],
        }),
      });
      const data=await res.json();
      if(data.error)throw new Error(data.error.message||JSON.stringify(data.error));
      reply=data.choices[0].message.content;
      chatHistory.push({role:'assistant',content:reply});
    }catch(err){reply=`⚠️ **API Error:** ${err.message}\n\nCheck your Groq API key in Settings → AI Configuration.`;}
  }else{
    reply=getDemoReply(txt);
  }
  
  document.getElementById(tid)?.remove();
  addChatBubble('ai',fmtMsg(reply));
  document.getElementById('sendBtn').disabled=false;
  const xpEl=document.getElementById('chatXP');
  xpEl.textContent='+'+(parseInt(xpEl.textContent.replace('+',''))+15);
  persistChatAct(txt);
  scrollChat();
}

function persistChatAct(q){
  const users=JSON.parse(localStorage.getItem('ex_users')||'{}');
  if(!users[currentUser.email])return;
  const d=users[currentUser.email].data;
  d.activity.unshift({subj:q.slice(0,45)+(q.length>45?'…':''),score:0,date:'Just now',type:'Chat'});
  if(d.activity.length>25)d.activity.pop();
  d.xp=(d.xp||0)+15;
  localStorage.setItem('ex_users',JSON.stringify(users));
}

function fmtMsg(text){
  text=text.replace(/```(\w+)?\n([\s\S]*?)```/g,(_,lang,code)=>
    `<div class="code-header">${lang||'code'}</div><pre><code>${esc(code.trim())}</code></pre>`);
  text=text.replace(/`([^`]+)`/g,'<code style="font-family:var(--mono);background:rgba(0,212,255,.08);padding:1px 5px;border-radius:3px;color:var(--cyan);font-size:11.5px">$1</code>');
  text=text.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');
  text=text.replace(/\n/g,'<br>');
  return text;
}

