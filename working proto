    if(users[saved]){
      setTimeout(()=>launchApp(users[saved]), 100);
    }
  }
  // Pre-fill API key if saved
  const k = localStorage.getItem('enginex_apikey');
  if(k) document.getElementById('apiKeyInput').value = k;
})();
