  const myXP = appData.xp;
  // Static peers — user's real XP is inserted in their slot
  const peers = [
    {n:'Priya Menon',    i:'P', xp:7840, streak:28, branch:'CSE', g:'135deg,#ff6eb4,var(--purple)'},
    {n:'Rahul Verma',    i:'R', xp:7210, streak:21, branch:'IT',  g:'135deg,#fbbf24,var(--orange)'},
    {n:'Aditya Nair',    i:'A', xp:5600, streak:15, branch:'CSE', g:'135deg,var(--cyan),#7dcfff'},
    {n:'Sneha Iyer',     i:'S', xp:4200, streak:9,  branch:'DS',  g:'135deg,var(--green),var(--cyan)'},
    {n:'Vikram Shah',    i:'V', xp:3900, streak:6,  branch:'IT',  g:'135deg,var(--orange),var(--red)'},
    {n:'Neha Krishnan',  i:'N', xp:3500, streak:4,  branch:'ECE', g:'135deg,var(--purple),var(--pink)'},
  ];
  const me = {
    n: `${currentUser?.fname || 'You'} ${currentUser?.lname || ''}`,
    i: (currentUser?.fname || 'Y')[0],
    xp: myXP, streak: appData.streak,
    branch: currentUser?.branch?.split(' ')[0] || 'CSE',
    isMe: true, g: '135deg,var(--cyan),var(--purple)',
  };
  const all = [...peers, me].sort((a, b) => b.xp - a.xp);
  const myRank = all.findIndex(l => l.isMe) + 1;
  const medals = ['🥇','🥈','🥉'];
  document.getElementById('leaderList').innerHTML = all.map((l, i) => `
    <div style="display:flex;align-items:center;gap:12px;padding:10px;border-radius:10px;margin-bottom:3px;
    background:${l.isMe?'rgba(0,229,255,.05)':'transparent'};border:${l.isMe?'1px solid rgba(0,229,255,.15)':'1px solid transparent'}">
      <div style="width:26px;text-align:center;font-family:var(--mono);font-size:${i<3?'16':'12'}px;font-weight:700;
      color:${i===0?'var(--yellow)':i===1?'#c0c0c0':i===2?'#cd7f32':'var(--muted2)'}">
        ${i < 3 ? medals[i] : '#'+(i+1)}</div>
      <div style="width:34px;height:34px;border-radius:50%;background:linear-gradient(${l.g});display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:var(--bg);flex-shrink:0">${l.i}</div>
      <div style="flex:1"><div style="font-size:13px;font-weight:600">${l.n}${l.isMe?' (You)':''}</div>
      <div style="font-family:var(--mono);font-size:10px;color:var(--muted2)">${l.branch} · 🔥${l.streak}</div></div>
      <div style="font-family:var(--mono);font-size:12px;font-weight:700;color:var(--cyan)">${l.xp.toLocaleString()} XP</div>
    </div>`).join('');

  document.getElementById('lbStreak').textContent = appData.streak;
  document.getElementById('lbXP').textContent     = myXP.toLocaleString();

  // Update rank display
  const rankEl = document.querySelector('#panel-leaderboard .sec-card:last-child');
  if (rankEl) {
    const rankNum = rankEl.querySelector('div[style*="52px"]');
    if (rankNum) rankNum.textContent = '#' + myRank;
    const xpNeeded = myRank > 1 ? all[myRank-2].xp - myXP : 0;
    const xpNeedEl = rankEl.querySelector('[style*="var(--yellow)"]');
    if (xpNeedEl) xpNeedEl.textContent = xpNeeded > 0 ? `+${xpNeeded} XP` : 'You\'re #1! 🏆';
  }
}

// ══════════════════════════════════════════ TOAST
function toast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className   = `toast ${type} show`;
  setTimeout(() => t.classList.remove('show'), 3200);
}

