    {n:'Aditya Nair',i:'A',xp:5600,streak:15,branch:'CSE',g:'135deg,#00d4ff,#60a5fa'},
    {n:'Sneha Iyer',i:'S',xp:4200,streak:9,branch:'DS',g:'135deg,#00ff88,#00d4ff'},
    {n:'Vikram Shah',i:'V',xp:3900,streak:6,branch:'IT',g:'135deg,#f97316,#ef4444'},
    {n:'Neha Krishnan',i:'N',xp:3500,streak:4,branch:'ECE',g:'135deg,#a78bfa,#f472b6'},
  ];
  const me={n:`${currentUser?.fname||'You'} ${currentUser?.lname||''}`.trim(),i:(currentUser?.fname||'Y')[0],
    xp:myXP,streak:appStats.streak,branch:currentUser?.branch?.split(' ')[0]||'CSE',
    isMe:true,g:'135deg,var(--cyan),var(--purple)'};
  const all=[...peers,me].sort((a,b)=>b.xp-a.xp);
  const myRank=all.findIndex(l=>l.isMe)+1;
  const medals=['🥇','🥈','🥉'];
  document.getElementById('lbList').innerHTML=all.map((l,i)=>`
    <div class="lb-row ${l.isMe?'me':''}">
      <div class="lb-rank" style="color:${i===0?'var(--yellow)':i===1?'#c0c0c0':i===2?'#cd7f32':'var(--muted2)'}; font-size:${i<3?'16':'11'}px">
        ${i<3?medals[i]:'#'+(i+1)}</div>
      <div class="lb-av" style="background:linear-gradient(${l.g})">${l.i}</div>
      <div class="lb-info">
        <div class="lb-name">${l.n}${l.isMe?' (You)':''}</div>
        <div class="lb-branch">${l.branch} · 🔥${l.streak}</div>
      </div>
      <div class="lb-xp">${l.xp.toLocaleString()} XP</div>
    </div>`).join('');
  document.getElementById('myRankNum').textContent='#'+myRank;
  document.getElementById('lbStreakNum').textContent=appStats.streak;
  document.getElementById('lbXPNum').textContent=myXP.toLocaleString();
  const needed=myRank>1?all[myRank-2].xp-myXP:0;
  document.getElementById('xpNeeded').textContent=needed>0?`+${needed} XP`:"You're #1! 🏆";
}

// ═══════════════════════════════════════════ AUTO LOGIN
(function boot(){
  const saved=localStorage.getItem('ex_session');
  if(saved){const u=(JSON.parse(localStorage.getItem('ex_users')||'{}')||{})[saved];if(u){setTimeout(()=>launchApp(u),100);return;}}
  const k=localStorage.getItem('ex_groqkey');
  if(k)document.getElementById('apiKeyInput').value=k;
})();
</script>
