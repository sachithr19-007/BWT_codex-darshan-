    const rd=ROADMAP_DATA[s.id];
    const phases=rd?rd.phases:[];
    const donePh=phases.filter(p=>p.done).length;
    const totalPh=phases.length||1;
    const pctRm=Math.round(donePh/totalPh*100);
    return `<button class="rm-nav-item ${s.id===activeRoadmap?'active':''}" onclick="switchRoadmap('${s.id}',this)">
      <span style="font-size:14px">${s.ico}</span>${s.nm}
      <span class="rm-nav-progress">${pctRm}%</span>
    </button>`;
  }).join('');
  renderRoadmap();
}

function switchRoadmap(id,el){
  activeRoadmap=id;
  document.querySelectorAll('.rm-nav-item').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  renderRoadmap();
}

function renderRoadmap(){
  const rd=ROADMAP_DATA[activeRoadmap];
  if(!rd){
    document.getElementById('rmContent').innerHTML=`<div style="color:var(--muted2);text-align:center;padding:40px;font-size:13px;">Roadmap coming soon 🚧</div>`;
    return;
  }
  const phases=rd.phases;
  const donePh=phases.filter(p=>p.done).length;
  const pct=Math.round(donePh/phases.length*100);
  const totalTopics=phases.reduce((a,p)=>a+p.topics.length,0);
  const doneTopics=phases.filter(p=>p.done).reduce((a,p)=>a+p.topics.length,0);
  
  let html=`<div class="rm-subject-header">
    <div class="rm-subj-ico">${rd.ico}</div>
    <div style="flex:1">
      <div class="rm-subj-title">${rd.nm} Roadmap</div>
