<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EngineX — Engineering Learning Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ════════════════════════════════════════ ROOT TOKENS */
:root{
  --bg:#060a0f;
  --surface:#0a0f16;
  --card:#0f1623;
  --card2:#141d2e;
  --border:rgba(255,255,255,0.06);
  --border2:rgba(255,255,255,0.11);
  --cyan:#00d4ff;
  --cyan2:#00aadd;
  --green:#00ff88;
  --orange:#ff8c42;
  --purple:#a78bfa;
  --pink:#f472b6;
  --yellow:#fbbf24;
  --red:#f87171;
  --blue:#60a5fa;
  --text:#dde6f0;
  --muted:#3d4d5c;
  --muted2:#6b7f92;
  --mono:'Space Mono',monospace;
  --sans:'Outfit',sans-serif;
  --sb:220px;
  --radius:12px;
  --shadow:0 8px 40px rgba(0,0,0,.5);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;line-height:1.5;}
::selection{background:rgba(0,212,255,.2);color:var(--cyan);}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--muted);border-radius:2px;}

/* SCAN LINES */
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,212,255,.008) 3px,rgba(0,212,255,.008) 4px);pointer-events:none;z-index:9997;}

/* UTILS */
.hidden{display:none!important;}
.mono{font-family:var(--mono);}
.btn{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border:none;border-radius:8px;font-family:var(--sans);font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;text-decoration:none;}
.btn-primary{background:var(--cyan);color:var(--bg);box-shadow:0 4px 20px rgba(0,212,255,.25);}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 8px 30px rgba(0,212,255,.4);}
.btn-ghost{background:rgba(255,255,255,.05);color:var(--text);border:1px solid var(--border2);}
.btn-ghost:hover{background:rgba(255,255,255,.09);border-color:rgba(255,255,255,.2);}
.tag{padding:3px 9px;border-radius:5px;font-family:var(--mono);font-size:10px;font-weight:700;display:inline-flex;align-items:center;gap:4px;}
.tag-cyan{background:rgba(0,212,255,.1);border:1px solid rgba(0,212,255,.25);color:var(--cyan);}
.tag-green{background:rgba(0,255,136,.1);border:1px solid rgba(0,255,136,.2);color:var(--green);}
.tag-orange{background:rgba(255,140,66,.1);border:1px solid rgba(255,140,66,.2);color:var(--orange);}
.tag-purple{background:rgba(167,139,250,.1);border:1px solid rgba(167,139,250,.2);color:var(--purple);}
.tag-red{background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.2);color:var(--red);}
.tag-yellow{background:rgba(251,191,36,.1);border:1px solid rgba(251,191,36,.2);color:var(--yellow);}

/* TOAST */
#toast{position:fixed;bottom:24px;right:24px;padding:12px 18px;border-radius:10px;font-size:13px;font-weight:600;z-index:9999;opacity:0;transform:translateY(8px);transition:all .3s;pointer-events:none;}
#toast.show{opacity:1;transform:translateY(0);}
#toast.success{background:rgba(0,255,136,.12);border:1px solid rgba(0,255,136,.3);color:var(--green);}
#toast.error{background:rgba(248,113,113,.12);border:1px solid rgba(248,113,113,.3);color:var(--red);}
#toast.info{background:rgba(0,212,255,.12);border:1px solid rgba(0,212,255,.3);color:var(--cyan);}

/* ════════════════════════════════════════ AUTH PAGE */
#authPage{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;position:relative;overflow:hidden;}
.auth-bg-grid{position:fixed;inset:0;z-index:0;background-image:linear-gradient(rgba(0,212,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,212,255,.025) 1px,transparent 1px);background-size:40px 40px;}
.auth-bg-glow{position:fixed;inset:0;z-index:0;
  background:radial-gradient(ellipse 60% 50% at 15% 50%,rgba(0,212,255,.06) 0,transparent 55%),
             radial-gradient(ellipse 40% 40% at 85% 25%,rgba(0,255,136,.05) 0,transparent 50%),
             radial-gradient(ellipse 35% 35% at 50% 95%,rgba(167,139,250,.06) 0,transparent 50%);}

.auth-container{position:relative;z-index:1;display:grid;grid-template-columns:1.1fr 1fr;gap:72px;align-items:center;max-width:960px;width:100%;}

/* LEFT HERO */
.auth-hero{animation:fadeUp .6s ease both;}
.brand-mark{display:inline-flex;align-items:center;gap:12px;margin-bottom:40px;}
.brand-icon{width:44px;height:44px;background:var(--cyan);border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-weight:700;font-size:16px;color:var(--bg);}
.brand-wordmark{font-family:var(--mono);font-size:20px;font-weight:700;color:var(--text);}
.brand-wordmark em{color:var(--cyan);font-style:normal;}

.auth-hero h1{font-size:clamp(2.4rem,4.8vw,3.6rem);font-weight:900;letter-spacing:-.04em;line-height:1.02;margin-bottom:16px;}
.auth-hero h1 .grad{background:linear-gradient(120deg,var(--cyan),var(--green) 60%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.auth-hero p{color:var(--muted2);font-size:14px;line-height:1.8;max-width:380px;margin-bottom:28px;}

.subject-pills{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:28px;}
.sp{padding:5px 13px;border-radius:20px;font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.03em;border:1px solid;white-space:nowrap;}

.auth-notice{background:rgba(0,255,136,.06);border:1px solid rgba(0,255,136,.15);border-radius:10px;padding:12px 14px;font-size:12px;color:var(--muted2);line-height:1.6;}
.auth-notice strong{color:var(--green);}

/* RIGHT CARD */
.auth-card{background:var(--card);border:1px solid var(--border2);border-radius:16px;padding:32px;box-shadow:0 32px 80px rgba(0,0,0,.6);animation:fadeUp .6s .1s ease both;}
.auth-tabs{display:flex;background:rgba(255,255,255,.04);border-radius:8px;padding:3px;margin-bottom:24px;gap:3px;}
.auth-tab{flex:1;padding:9px;border:none;border-radius:6px;background:transparent;color:var(--muted2);font-family:var(--sans);font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;}
.auth-tab.active{background:var(--cyan);color:var(--bg);}

.form-section{display:none;}
.form-section.active{display:block;}
.form-group{margin-bottom:15px;}
.form-group label{display:block;font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.07em;color:var(--muted2);margin-bottom:6px;text-transform:uppercase;}
.inp-wrap{position:relative;}
.inp-ico{position:absolute;left:13px;top:50%;transform:translateY(-50%);font-size:14px;opacity:.45;pointer-events:none;}
.form-group input,.form-group select{width:100%;padding:11px 12px 11px 40px;background:rgba(255,255,255,.04);border:1px solid var(--border2);border-radius:8px;color:var(--text);font-family:var(--sans);font-size:13.5px;outline:none;transition:border-color .2s,background .2s;-webkit-appearance:none;}
.form-group input:focus,.form-group select:focus{border-color:var(--cyan);background:rgba(0,212,255,.03);}
.form-group select option{background:var(--card);}
.row-2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.msg-box{border-radius:8px;padding:9px 13px;font-size:12.5px;margin-bottom:14px;display:none;}
.msg-err{background:rgba(248,113,113,.09);border:1px solid rgba(248,113,113,.25);color:var(--red);}
.msg-ok{background:rgba(0,255,136,.08);border:1px solid rgba(0,255,136,.2);color:var(--green);}

.btn-auth-full{width:100%;padding:13px;background:var(--cyan);border:none;border-radius:9px;color:var(--bg);font-family:var(--sans);font-size:14px;font-weight:700;cursor:pointer;transition:all .2s;box-shadow:0 4px 20px rgba(0,212,255,.2);}
.btn-auth-full:hover{transform:translateY(-1px);box-shadow:0 8px 28px rgba(0,212,255,.35);}

.divider{display:flex;align-items:center;gap:10px;margin:18px 0;color:var(--muted);font-size:11px;font-family:var(--mono);}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--border2);}

.google-btn{width:100%;padding:11px;background:rgba(255,255,255,.06);border:1px solid var(--border2);border-radius:9px;color:var(--text);font-family:var(--sans);font-size:13.5px;font-weight:600;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:10px;}
.google-btn:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.2);}
.google-icon{width:18px;height:18px;}

.api-setup-box{background:rgba(167,139,250,.05);border:1px solid rgba(167,139,250,.18);border-radius:10px;padding:14px;margin-top:16px;}
.api-setup-box p{font-size:11.5px;color:var(--muted2);margin-bottom:10px;line-height:1.6;}
.api-setup-box a{color:var(--purple);text-decoration:none;}
.api-setup-box a:hover{text-decoration:underline;}
.api-row{display:flex;gap:8px;}
.api-row input{flex:1;padding:9px 12px;background:rgba(255,255,255,.04);border:1px solid rgba(167,139,250,.2);border-radius:7px;color:var(--text);font-family:var(--mono);font-size:11px;outline:none;transition:border-color .2s;}
.api-row input:focus{border-color:var(--purple);}
.api-row button{padding:9px 14px;background:rgba(167,139,250,.12);border:1px solid rgba(167,139,250,.25);border-radius:7px;color:var(--purple);font-family:var(--sans);font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;white-space:nowrap;}
.api-row button:hover{background:rgba(167,139,250,.2);}

/* ════════════════════════════════════════ APP SHELL */
#appShell{display:flex;min-height:100vh;}

/* SIDEBAR */
.sidebar{width:var(--sb);background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:200;transition:transform .3s;}
.sb-top{padding:18px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.sb-logo{width:34px;height:34px;background:var(--cyan);border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-weight:700;font-size:13px;color:var(--bg);flex-shrink:0;}
.sb-title{font-family:var(--mono);font-size:14px;font-weight:700;line-height:1.2;}
.sb-title em{color:var(--cyan);font-style:normal;}
.sb-version{font-size:9px;color:var(--muted);font-family:var(--mono);}

nav.sb-nav{padding:12px 10px;flex:1;overflow-y:auto;}
.nav-group{margin-bottom:18px;}
.nav-group-label{font-family:var(--mono);font-size:9px;font-weight:700;letter-spacing:.12em;color:var(--muted);padding:0 8px;margin-bottom:4px;text-transform:uppercase;}
.nav-item{display:flex;align-items:center;gap:9px;padding:9px 10px;border-radius:8px;cursor:pointer;font-size:13px;font-weight:500;color:var(--muted2);transition:all .15s;border:none;background:transparent;width:100%;text-align:left;font-family:var(--sans);}
.nav-item:hover{background:rgba(255,255,255,.05);color:var(--text);}
.nav-item.active{background:rgba(0,212,255,.08);color:var(--cyan);border:1px solid rgba(0,212,255,.14);}
.nav-ico{font-size:15px;width:20px;text-align:center;flex-shrink:0;}
.nav-badge{margin-left:auto;padding:1px 7px;border-radius:10px;font-size:9px;font-weight:700;font-family:var(--mono);}
.nb-live{background:rgba(0,255,136,.15);color:var(--green);}
.nb-new{background:rgba(248,113,113,.2);color:var(--red);}

.sb-bottom{padding:14px 16px;border-top:1px solid var(--border);}
.sb-user{display:flex;align-items:center;gap:10px;}
.sb-av{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--cyan),var(--purple));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:var(--bg);flex-shrink:0;cursor:pointer;}
.sb-info{flex:1;min-width:0;}
.sb-name{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sb-role{font-family:var(--mono);font-size:9.5px;color:var(--muted2);}
.sb-logout{background:none;border:none;cursor:pointer;color:var(--muted);font-size:16px;padding:3px;transition:color .2s;margin-left:auto;}
.sb-logout:hover{color:var(--red);}

/* MAIN */
.main{margin-left:var(--sb);flex:1;min-height:100vh;display:flex;flex-direction:column;}
.topbar{padding:16px 28px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);background:var(--bg);position:sticky;top:0;z-index:100;}
.topbar-left .page-title{font-size:18px;font-weight:800;letter-spacing:-.02em;}
.topbar-left .page-sub{font-size:11px;color:var(--muted2);font-family:var(--mono);margin-top:1px;}
.topbar-right{display:flex;align-items:center;gap:10px;}
.search-wrap{display:flex;align-items:center;gap:8px;background:var(--card);border:1px solid var(--border2);border-radius:8px;padding:8px 12px;width:185px;}
.search-wrap input{background:none;border:none;outline:none;color:var(--text);font-family:var(--sans);font-size:12.5px;width:100%;}
.search-wrap input::placeholder{color:var(--muted);}
.icon-btn{width:36px;height:36px;background:var(--card);border:1px solid var(--border2);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;cursor:pointer;transition:background .2s;position:relative;}
.icon-btn:hover{background:rgba(255,255,255,.07);}
.notif-dot{position:absolute;top:6px;right:6px;width:6px;height:6px;background:var(--red);border-radius:50%;border:2px solid var(--bg);}

.page-content{padding:24px 28px;flex:1;}

/* PANELS */
.panel{display:none;}
.panel.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.anim{animation:fadeUp .35s ease both;}

/* ════════════════════════════════════════ DASHBOARD */
.welcome-band{background:linear-gradient(135deg,rgba(0,212,255,.08),rgba(0,255,136,.04));border:1px solid rgba(0,212,255,.15);border-radius:14px;padding:20px 24px;margin-bottom:18px;display:flex;align-items:center;justify-content:space-between;position:relative;overflow:hidden;}
.welcome-band::before{content:'{ engineer }';position:absolute;right:200px;top:50%;transform:translateY(-50%);font-family:var(--mono);font-size:70px;font-weight:700;color:rgba(0,212,255,.035);white-space:nowrap;pointer-events:none;}
.wb-heading{font-size:17px;font-weight:800;letter-spacing:-.02em;margin-bottom:3px;}
.wb-sub{color:var(--muted2);font-size:12.5px;}
.streak-box{background:rgba(255,140,66,.08);border:1px solid rgba(255,140,66,.2);border-radius:10px;padding:12px 16px;text-align:center;flex-shrink:0;}
.streak-fire{font-size:20px;}
.streak-num{font-family:var(--mono);font-size:24px;font-weight:700;color:var(--orange);line-height:1;}
.streak-label{font-family:var(--mono);font-size:9px;color:var(--muted2);text-transform:uppercase;letter-spacing:.06em;}

.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:18px;}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;transition:transform .2s,border-color .2s;}
.stat-card:hover{transform:translateY(-2px);border-color:var(--border2);}
.stat-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.stat-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;}
.stat-delta{font-family:var(--mono);font-size:9.5px;font-weight:700;padding:2px 7px;border-radius:4px;}
.delta-pos{background:rgba(0,255,136,.1);color:var(--green);}
.delta-neg{background:rgba(248,113,113,.1);color:var(--red);}
.stat-val{font-size:26px;font-weight:800;letter-spacing:-.03em;margin-bottom:2px;line-height:1;}
.stat-lbl{font-size:11.5px;color:var(--muted2);}

.two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:18px;}
.three-col{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:18px;}
.sec-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;}
.sec-title{font-size:12.5px;font-weight:700;letter-spacing:-.01em;display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.sec-action{font-family:var(--mono);font-size:10px;color:var(--cyan);cursor:pointer;background:none;border:none;font-family:var(--mono);}

.lang-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:9px;}
.lb-ico{font-size:14px;width:24px;text-align:center;}
.lb-info{flex:1;}
.lb-name{font-size:11.5px;font-weight:600;display:flex;justify-content:space-between;margin-bottom:3px;}
.lb-name span{font-family:var(--mono);font-size:10px;}
.lb-track{height:4px;border-radius:2px;background:rgba(255,255,255,.06);}
.lb-fill{height:100%;border-radius:2px;transition:width 1.2s ease;}

.act-row{display:flex;align-items:flex-start;gap:10px;padding:9px 0;border-bottom:1px solid var(--border);}
.act-row:last-child{border:none;padding-bottom:0;}
.act-dot{width:6px;height:6px;border-radius:50%;margin-top:5px;flex-shrink:0;}
.act-title{font-size:12.5px;font-weight:500;margin-bottom:1px;}
.act-meta{font-family:var(--mono);font-size:9.5px;color:var(--muted);}
.act-score{font-family:var(--mono);font-size:11.5px;font-weight:700;margin-left:auto;flex-shrink:0;}

/* ════════════════════════════════════════ AI TUTOR */
.tutor-layout{display:grid;grid-template-columns:1fr 270px;gap:16px;height:calc(100vh - 120px);}
.chat-panel{background:var(--card);border:1px solid var(--border);border-radius:14px;display:flex;flex-direction:column;overflow:hidden;}
.chat-header{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;}
.ai-avatar{width:36px;height:36px;background:linear-gradient(135deg,var(--cyan),var(--purple));border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-weight:700;font-size:12px;color:var(--bg);flex-shrink:0;}
.ai-online{font-family:var(--mono);font-size:10px;color:var(--green);display:flex;align-items:center;gap:5px;}
.ai-online::before{content:'';width:5px;height:5px;background:var(--green);border-radius:50%;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.4;}}
.model-tag{font-family:var(--mono);font-size:9.5px;padding:2px 8px;border-radius:4px;background:rgba(167,139,250,.1);border:1px solid rgba(167,139,250,.2);color:var(--purple);margin-left:auto;}

.chat-messages{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px;}
.chat-msg{max-width:84%;animation:fadeUp .3s ease;}
.chat-msg.user{align-self:flex-end;}
.msg-label{font-family:var(--mono);font-size:8.5px;font-weight:700;letter-spacing:.08em;color:var(--muted);margin-bottom:4px;text-transform:uppercase;}
.chat-msg.user .msg-label{text-align:right;}
.msg-bubble{padding:10px 14px;border-radius:10px;font-size:13px;line-height:1.7;}
.chat-msg.ai .msg-bubble{background:rgba(255,255,255,.04);border:1px solid var(--border2);border-radius:3px 10px 10px 10px;}
.chat-msg.user .msg-bubble{background:var(--cyan);color:var(--bg);font-weight:500;border-radius:10px 10px 3px 10px;}
.msg-bubble pre{background:var(--bg);border:1px solid rgba(0,212,255,.14);border-radius:8px;padding:12px 14px;margin:8px 0;overflow-x:auto;}
.msg-bubble pre code{font-family:var(--mono);font-size:11.5px;line-height:1.6;color:var(--green);}
.msg-bubble .code-header{font-family:var(--mono);font-size:9px;color:var(--cyan);background:rgba(0,212,255,.07);padding:2px 8px;border-radius:4px;margin-bottom:5px;display:inline-block;}
.msg-bubble strong{color:var(--cyan);}
.typing-anim span{display:inline-block;width:5px;height:5px;background:var(--cyan);border-radius:50%;margin:0 2px;animation:typeBounce 1.2s infinite;}
.typing-anim span:nth-child(2){animation-delay:.2s;}
.typing-anim span:nth-child(3){animation-delay:.4s;}
@keyframes typeBounce{0%,60%,100%{transform:translateY(0);}30%{transform:translateY(-6px);}}

.chat-input-bar{padding:12px 16px;border-top:1px solid var(--border);display:flex;gap:8px;align-items:flex-end;}
.chat-textarea{flex:1;background:rgba(255,255,255,.04);border:1px solid var(--border2);border-radius:9px;padding:10px 13px;color:var(--text);font-family:var(--sans);font-size:13px;resize:none;outline:none;max-height:110px;line-height:1.5;transition:border-color .2s;}
.chat-textarea:focus{border-color:var(--cyan);}
.send-btn{width:40px;height:40px;background:var(--cyan);border:none;border-radius:8px;cursor:pointer;font-size:16px;color:var(--bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s;}
.send-btn:hover{transform:scale(1.06);box-shadow:0 4px 14px rgba(0,212,255,.35);}
.send-btn:disabled{opacity:.3;cursor:not-allowed;transform:none;box-shadow:none;}

.tutor-sidebar{display:flex;flex-direction:column;gap:14px;overflow-y:auto;}
.quick-chip{padding:9px 12px;border-radius:7px;background:rgba(255,255,255,.025);border:1px solid var(--border);color:var(--text);font-family:var(--sans);font-size:11.5px;font-weight:500;cursor:pointer;text-align:left;transition:all .15s;display:block;width:100%;}
.quick-chip:hover{background:rgba(0,212,255,.06);border-color:rgba(0,212,255,.2);color:var(--cyan);}
.chip-lang{font-family:var(--mono);font-size:9px;color:var(--muted2);margin-right:4px;}

/* ════════════════════════════════════════ MOCK TESTS */
.quiz-setup{max-width:640px;margin:0 auto;padding:10px 0;}
.quiz-setup-title{font-size:26px;font-weight:800;letter-spacing:-.03em;margin-bottom:6px;}
.quiz-setup-sub{color:var(--muted2);font-size:13px;margin-bottom:26px;}
.subj-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:22px;}
.subj-card{background:var(--card);border:2px solid var(--border);border-radius:12px;padding:14px 10px;cursor:pointer;transition:all .2s;text-align:center;}
.subj-card:hover,.subj-card.sel{border-color:var(--cyan);}
.subj-card.sel{background:rgba(0,212,255,.06);}
.subj-card-ico{font-size:24px;margin-bottom:6px;}
.subj-card-name{font-size:12px;font-weight:700;margin-bottom:2px;}
.subj-card-count{font-family:var(--mono);font-size:9.5px;color:var(--muted2);}

.diff-picker{display:flex;gap:8px;justify-content:center;margin-bottom:24px;}
.diff-btn{padding:7px 20px;border-radius:7px;border:1.5px solid var(--border2);font-family:var(--mono);font-size:11.5px;font-weight:700;cursor:pointer;background:transparent;color:var(--muted2);transition:all .2s;}
.diff-easy.active{border-color:var(--green);background:rgba(0,255,136,.08);color:var(--green);}
.diff-med.active{border-color:var(--yellow);background:rgba(251,191,36,.08);color:var(--yellow);}
.diff-hard.active{border-color:var(--red);background:rgba(248,113,113,.08);color:var(--red);}
.diff-btn:hover{border-color:var(--border2);}

.quiz-mode-row{display:flex;gap:10px;justify-content:center;margin-bottom:24px;}
.mode-card{flex:1;max-width:160px;padding:12px;border-radius:10px;border:1.5px solid var(--border);background:var(--card);cursor:pointer;text-align:center;transition:all .2s;}
.mode-card:hover,.mode-card.sel{border-color:var(--cyan);background:rgba(0,212,255,.04);}
.mode-ico{font-size:20px;margin-bottom:5px;}
.mode-nm{font-size:12px;font-weight:700;}
.mode-desc{font-size:11px;color:var(--muted2);}

.quiz-start-btn{width:100%;max-width:320px;padding:13px;background:var(--cyan);border:none;border-radius:10px;color:var(--bg);font-family:var(--sans);font-size:14px;font-weight:700;cursor:pointer;box-shadow:0 4px 20px rgba(0,212,255,.2);transition:all .2s;display:block;margin:0 auto;}
.quiz-start-btn:hover{transform:translateY(-1px);box-shadow:0 8px 28px rgba(0,212,255,.35);}

/* ACTIVE QUIZ */
.quiz-active-wrap{max-width:680px;margin:0 auto;}
.q-header{display:flex;align-items:center;gap:14px;margin-bottom:20px;}
.q-counter{font-family:var(--mono);font-size:11.5px;font-weight:700;color:var(--muted2);}
.q-progress{flex:1;height:4px;background:rgba(255,255,255,.07);border-radius:2px;overflow:hidden;}
.q-progress-fill{height:100%;background:var(--cyan);border-radius:2px;transition:width .4s ease;}
.q-timer{font-family:var(--mono);font-size:12.5px;font-weight:700;padding:5px 13px;border-radius:7px;background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.2);color:var(--red);}

.q-card{background:var(--card);border:1px solid var(--border2);border-radius:16px;padding:26px;}
.q-tags{display:flex;gap:7px;margin-bottom:14px;flex-wrap:wrap;}
.q-text{font-size:16px;font-weight:700;line-height:1.6;margin-bottom:22px;letter-spacing:-.01em;}
.q-text code{font-family:var(--mono);background:rgba(0,212,255,.08);padding:1px 6px;border-radius:4px;font-size:13px;color:var(--cyan);}
.q-options{display:flex;flex-direction:column;gap:8px;}
.q-option{padding:12px 15px;border-radius:9px;border:1.5px solid var(--border2);background:rgba(255,255,255,.02);cursor:pointer;font-size:13px;font-weight:500;transition:all .15s;display:flex;align-items:center;gap:11px;}
.q-option:hover{border-color:var(--cyan);background:rgba(0,212,255,.04);}
.q-option.chosen{border-color:var(--purple);background:rgba(167,139,250,.06);}
.q-option.correct{border-color:var(--green)!important;background:rgba(0,255,136,.07)!important;}
.q-option.wrong{border-color:var(--red)!important;background:rgba(248,113,113,.06)!important;}
.q-opt-letter{width:26px;height:26px;border-radius:6px;background:rgba(255,255,255,.05);display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:11px;font-weight:700;flex-shrink:0;}
.q-option code{font-family:var(--mono);background:rgba(255,255,255,.06);padding:1px 5px;border-radius:3px;font-size:11.5px;}
.q-footer{display:flex;align-items:center;justify-content:space-between;margin-top:18px;}
.q-feedback{font-size:12.5px;flex:1;padding-right:14px;}
.btn-next-q{padding:9px 22px;background:var(--cyan);border:none;border-radius:8px;color:var(--bg);font-family:var(--sans);font-size:12.5px;font-weight:700;cursor:pointer;transition:all .2s;}
.btn-next-q:disabled{opacity:.3;cursor:not-allowed;}

/* QUIZ RESULTS */
.quiz-results{max-width:520px;margin:0 auto;text-align:center;padding:10px 0;}
.result-ring{width:128px;height:128px;border-radius:50%;background:conic-gradient(var(--cyan) var(--fill),rgba(255,255,255,.05) 0);display:flex;align-items:center;justify-content:center;position:relative;margin:0 auto 20px;}
.result-ring::before{content:'';position:absolute;width:98px;height:98px;background:var(--bg);border-radius:50%;}
.result-pct{position:relative;z-index:1;font-family:var(--mono);font-size:26px;font-weight:700;color:var(--cyan);}
.result-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:20px 0;}
.result-stat{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:13px;}
.rs-val{font-family:var(--mono);font-size:20px;font-weight:700;}
.rs-lbl{font-size:10.5px;color:var(--muted2);margin-top:2px;}
.ai-insight-box{background:rgba(167,139,250,.06);border:1px solid rgba(167,139,250,.18);border-radius:10px;padding:13px;margin:14px 0;text-align:left;font-size:12.5px;color:var(--muted2);line-height:1.65;}
.ai-insight-box strong{color:var(--purple);}

/* ════════════════════════════════════════ ROADMAPS — FULL PAGE */
.roadmap-page-layout{display:grid;grid-template-columns:200px 1fr;gap:20px;min-height:calc(100vh - 120px);}
.roadmap-nav-panel{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px;height:fit-content;position:sticky;top:90px;}
.roadmap-nav-title{font-family:var(--mono);font-size:9px;font-weight:700;letter-spacing:.1em;color:var(--muted);text-transform:uppercase;padding:0 8px;margin-bottom:8px;}
.rm-nav-item{display:flex;align-items:center;gap:8px;padding:9px 10px;border-radius:7px;cursor:pointer;font-size:12.5px;font-weight:500;color:var(--muted2);transition:all .15s;width:100%;border:none;background:transparent;text-align:left;font-family:var(--sans);}
.rm-nav-item:hover{background:rgba(255,255,255,.05);color:var(--text);}
.rm-nav-item.active{background:rgba(0,212,255,.08);color:var(--cyan);}
.rm-nav-progress{margin-left:auto;font-family:var(--mono);font-size:9px;font-weight:700;color:var(--muted);}
.rm-nav-item.active .rm-nav-progress{color:var(--cyan);}

.roadmap-content-panel{min-width:0;}
.rm-subject-header{background:linear-gradient(135deg,var(--card),var(--card2));border:1px solid var(--border2);border-radius:14px;padding:20px 24px;margin-bottom:20px;display:flex;align-items:center;gap:16px;}
.rm-subj-ico{font-size:38px;}
.rm-subj-title{font-size:22px;font-weight:800;letter-spacing:-.02em;margin-bottom:4px;}
.rm-subj-sub{font-size:12.5px;color:var(--muted2);}
.rm-meta{display:flex;gap:10px;margin-top:8px;flex-wrap:wrap;}

.rm-overall-progress{margin-left:auto;text-align:right;}
.rm-overall-pct{font-family:var(--mono);font-size:28px;font-weight:700;color:var(--cyan);line-height:1;}
.rm-overall-label{font-size:11px;color:var(--muted2);}
.rm-overall-bar{width:120px;height:6px;background:rgba(255,255,255,.07);border-radius:3px;overflow:hidden;margin-top:6px;}
.rm-overall-fill{height:100%;border-radius:3px;transition:width 1s ease;}

.rm-track{position:relative;padding-left:36px;}
.rm-track::before{content:'';position:absolute;left:13px;top:20px;bottom:20px;width:2px;background:linear-gradient(to bottom,var(--cyan),rgba(0,212,255,.1));}

.rm-phase-block{position:relative;margin-bottom:22px;}
.rm-phase-dot{position:absolute;left:-36px;top:8px;width:26px;height:26px;border-radius:50%;border:2px solid var(--border2);background:var(--bg);display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:10px;font-weight:700;color:var(--muted2);transition:all .3s;z-index:1;}
.rm-phase-dot.done{background:var(--cyan);border-color:var(--cyan);color:var(--bg);}
.rm-phase-dot.current{border-color:var(--cyan);color:var(--cyan);box-shadow:0 0 12px rgba(0,212,255,.35);}
.rm-phase-dot.locked{opacity:.4;}

.rm-phase-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px;transition:border-color .2s;}
.rm-phase-card.done-phase{border-color:rgba(0,255,136,.15);}
.rm-phase-card.current-phase{border-color:rgba(0,212,255,.2);}
.rm-phase-card.locked-phase{opacity:.6;}
.rm-phase-card-header{display:flex;align-items:center;gap:10px;margin-bottom:12px;}
.rm-phase-title{font-size:13.5px;font-weight:700;}
.rm-phase-status{margin-left:auto;}
.rm-topics-wrap{display:flex;flex-wrap:wrap;gap:6px;}
.rm-topic-chip{padding:4px 11px;border-radius:5px;font-size:11px;font-weight:600;font-family:var(--mono);cursor:pointer;transition:all .2s;}
.rm-topic-done{background:rgba(0,255,136,.08);border:1px solid rgba(0,255,136,.2);color:var(--green);text-decoration:line-through;opacity:.65;}
.rm-topic-active{background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.2);color:var(--cyan);}
.rm-topic-locked{background:rgba(255,255,255,.03);border:1px solid var(--border);color:var(--muted);}

.rm-resources{margin-top:12px;padding-top:12px;border-top:1px solid var(--border);}
.rm-res-title{font-family:var(--mono);font-size:9.5px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:7px;}
.rm-res-links{display:flex;gap:6px;flex-wrap:wrap;}
.rm-res-link{padding:4px 10px;border-radius:5px;font-size:11px;font-family:var(--mono);background:rgba(255,255,255,.04);border:1px solid var(--border2);color:var(--muted2);cursor:pointer;transition:all .2s;text-decoration:none;}
.rm-res-link:hover{background:rgba(0,212,255,.06);color:var(--cyan);border-color:rgba(0,212,255,.2);}

/* ════════════════════════════════════════ PROGRESS */
.progress-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:18px;}
.week-bars{display:flex;align-items:flex-end;gap:6px;height:80px;}
.week-bar-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;}
.week-bar{width:100%;border-radius:3px;transition:height .6s ease;}
.week-bar-lbl{font-family:var(--mono);font-size:8.5px;color:var(--muted2);}
.week-days{display:flex;justify-content:space-around;margin-top:6px;}
.week-day{font-family:var(--mono);font-size:9px;color:var(--muted2);}

/* ════════════════════════════════════════ LEADERBOARD */
.lb-row{display:flex;align-items:center;gap:12px;padding:10px;border-radius:9px;margin-bottom:3px;transition:background .15s;}
.lb-row:hover{background:rgba(255,255,255,.03);}
.lb-row.me{background:rgba(0,212,255,.05);border:1px solid rgba(0,212,255,.12);}
.lb-rank{width:26px;text-align:center;font-family:var(--mono);font-size:11px;font-weight:700;color:var(--muted2);}
.lb-av{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:var(--bg);flex-shrink:0;}
.lb-info{flex:1;min-width:0;}
.lb-name{font-size:12.5px;font-weight:600;}
.lb-branch{font-family:var(--mono);font-size:9.5px;color:var(--muted2);}
.lb-xp{font-family:var(--mono);font-size:11.5px;font-weight:700;color:var(--cyan);}

/* ════════════════════════════════════════ PROFILE */
.profile-hero{background:linear-gradient(135deg,var(--card),rgba(0,212,255,.05));border:1px solid var(--border2);border-radius:14px;padding:22px 26px;display:flex;align-items:center;gap:20px;margin-bottom:18px;}
.prof-av-big{width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,var(--cyan),var(--purple));display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:900;color:var(--bg);flex-shrink:0;}
.prof-name{font-size:20px;font-weight:800;letter-spacing:-.02em;margin-bottom:3px;}
.prof-branch{font-family:var(--mono);font-size:10.5px;color:var(--muted2);margin-bottom:10px;}
.prof-badges-row{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;}
.xp-progress-wrap{max-width:340px;}
.xp-labels-row{display:flex;justify-content:space-between;font-family:var(--mono);font-size:9.5px;color:var(--muted2);margin-bottom:4px;}
.xp-track{height:6px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden;}
.xp-fill{height:100%;background:linear-gradient(90deg,var(--cyan),var(--purple));border-radius:3px;transition:width 1.2s ease;}

/* ════════════════════════════════════════ SETTINGS */
.settings-col{max-width:560px;}
.set-group{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:14px;}
.set-group-title{font-size:12.5px;font-weight:700;display:flex;align-items:center;gap:7px;margin-bottom:14px;}
.set-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);}
.set-row:last-child{border:none;padding-bottom:0;}
.set-label{font-size:13px;font-weight:600;margin-bottom:2px;}
.set-desc{font-size:11.5px;color:var(--muted2);}
.toggle{width:40px;height:21px;border-radius:11px;position:relative;cursor:pointer;transition:background .2s;flex-shrink:0;}
.toggle.on{background:var(--cyan);}
.toggle.off{background:rgba(255,255,255,.1);}
.toggle::after{content:'';position:absolute;top:2.5px;width:16px;height:16px;background:#fff;border-radius:50%;transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.3);}
.toggle.on::after{left:21.5px;}
.toggle.off::after{left:2.5px;}

/* ════════════════════════════════════════ RESPONSIVE */
@media(max-width:900px){
  .auth-container{grid-template-columns:1fr;max-width:420px;}
  .auth-hero{display:none;}
  .sidebar{transform:translateX(-100%);}
  .main{margin-left:0;}
  .stats-row{grid-template-columns:1fr 1fr;}
  .two-col,.three-col,.tutor-layout,.roadmap-page-layout,.progress-grid{grid-template-columns:1fr;}
  .subj-grid{grid-template-columns:repeat(2,1fr);}
}
